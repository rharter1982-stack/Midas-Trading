      <div class="quant-box"><div style="color:var(--muted);font-size:8px">VOL RATIO</div><div style="font-size:16px;font-weight:bold;margin-top:4px" id="q-vol">—</div><div style="color:var(--muted);font-size:9px;margin-top:2px" id="q-vol-s">vs 20-day avg</div></div>
      <div class="quant-box"><div style="color:var(--muted);font-size:8px">VWAP SPREAD</div><div style="font-size:16px;font-weight:bold;margin-top:4px" id="q-vwap">—</div><div style="color:var(--muted);font-size:9px;margin-top:2px" id="q-vwap-s">Price vs VWAP</div></div>

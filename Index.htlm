    <button class="admin-sub-btn" id="asub-apis" onclick="showAdminTab('apis')" style="background:#050400;border:1px solid var(--gold-border);color:var(--muted);padding:6px 14px;border-radius:5px;cursor:pointer;font-size:9px;letter-spacing:1px;font-family:inherit">⚡ API STATUS</button>

      <div class="quant-box"><div style="color:var(--muted);font-size:8px">HIST. VOL</div><div style="font-size:16px;font-weight:bold;margin-top:4px" id="q-hv">—</div><div style="color:var(--muted);font-size:9px;margin-top:2px" id="q-hv-s">Daily avg move</div></div>

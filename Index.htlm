      </div>
      <button onclick="runApiHealthCheck()" id="api-check-btn" style="background:var(--gold-bg);border:1px solid var(--gold);color:var(--gold);padding:6px 14px;border-radius:5px;cursor:pointer;font-size:9px;letter-spacing:1px;font-family:inherit">⚡ RUN CHECK</button>
    </div>
    <div id="api-status-grid"></div>
    <div id="api-last-check" style="color:var(--muted);font-size:8px;text-align:center;margin-top:10px"></div>
    <div class="footer-note" style="margin-top:10px">⚡ Health checks make real API calls. Free tier limits apply.</div>
  </div>

</div>

</div><!-- end app-wrapper -->


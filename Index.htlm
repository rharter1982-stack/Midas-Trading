  <!-- USERS PANEL -->

  <div id="admin-users-panel">
  <div class="admin-panel">
    <div style="color:var(--admin);font-size:11px;letter-spacing:2px;margin-bottom:12px">⚙️ MIDAS ADMIN — USER MANAGEMENT</div>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
      <div style="color:var(--muted);font-size:9px" id="admin-count">0 users</div>
      <button onclick="toggleAddForm()" style="background:var(--admin-bg);border:1px solid #5a2a8a;color:var(--admin);padding:4px 10px;border-radius:4px;cursor:pointer;font-size:9px;font-family:inherit">+ ADD USER</button>
    </div>
    <div id="add-form" style="display:none;background:#050400;border:1px solid var(--gold-border);border-radius:6px;padding:12px;margin-bottom:10px">
      <div style="color:var(--admin);font-size:9px;margin-bottom:8px">NEW USER</div>
      <div class="form-row"><input class="form-input" id="nu-user" placeholder="Username" autocomplete="off" autocorrect="off" autocapitalize="off"/><input class="form-input" id="nu-pass" type="password" placeholder="Password"/></div>
      <div class="form-row">
        <select class="form-select" id="nu-tier"><option value="free">FREE — $0</option><option value="bronze">🥉 BRONZE — $5/mo</option><option value="silver">🥈 SILVER — $10/mo</option><option value="gold">🥇 GOLD — $15/mo</option></select>
        <input class="form-input" id="nu-exp" type="date" style="color:#fff;background:#1a1400;color-scheme:dark" title="Expiry date"/>
      </div>
      <div style="display:flex;gap:8px"><button onclick="adminAdd()" style="padding:8px 16px;border-radius:4px;cursor:pointer;font-family:inherit;font-size:10px;background:var(--gold-bg);border:1px solid var(--gold);color:var(--gold)">✅ CREATE</button><button onclick="toggleAddForm()" style="padding:8px 16px;border-radius:4px;cursor:pointer;font-family:inherit;font-size:10px;background:transparent;border:1px solid var(--gold-border);color:var(--muted)">CANCEL</button></div>
      <div id="add-err" style="color:var(--red);font-size:9px;margin-top:6px"></div>
    </div>
    <div id="user-list"></div>
  </div>
  <div id="edit-panel" style="display:none;background:#050400;border:1px solid var(--gold-border);border-radius:6px;padding:12px;margin-bottom:12px">
    <div style="color:var(--admin);font-size:9px;margin-bottom:8px">EDIT: <span id="edit-name" style="color:var(--text)"></span></div>
    <div class="form-row"><select class="form-select" id="edit-tier"><option value="free">FREE</option><option value="bronze">🥉 BRONZE</option><option value="silver">🥈 SILVER</option><option value="gold">🥇 GOLD</option></select><input class="form-input" id="edit-exp" type="date" style="color:#fff;background:#1a1400;color-scheme:dark"/></div>
    <div class="form-row"><input class="form-input" id="edit-pass" type="password" placeholder="New password (optional)" style="color:#fff;background:#1a1400"/></div>
    <div style="display:flex;gap:8px"><button onclick="adminSave()" style="padding:8px 16px;border-radius:4px;cursor:pointer;font-family:inherit;font-size:10px;background:var(--gold-bg);border:1px solid var(--gold);color:var(--gold)">💾 SAVE</button><button onclick="document.getElementById('edit-panel').style.display='none'" style="padding:8px 16px;border-radius:4px;cursor:pointer;font-family:inherit;font-size:10px;background:transparent;border:1px solid var(--gold-border);color:var(--muted)">CANCEL</button></div>
  </div>
  <div class="footer-note">User data stored in localStorage on this device.</div>
  </div><!-- end admin-users-panel -->

  <!-- API STATUS PANEL -->

  <div id="admin-apis-panel" style="display:none">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
      <div>
        <div style="color:var(--gold);font-size:11px;letter-spacing:2px">⚡ API & DATA SOURCE STATUS</div>

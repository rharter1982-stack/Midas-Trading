// Merge and deduplicate news from all sources
function mergeNews(finnNews, avResult){
  var avNews=avResult&&avResult.articles||[];
  var all=[];
  // Add AV news first (has sentiment scores)
  avNews.forEach(function(n){all.push(n);});
  // Add Finnhub news, skip duplicates (similar headline)
  finnNews.forEach(function(fn){
    var isDup=all.some(function(a){
      return a.headline&&fn.headline&&
        a.headline.substring(0,40).toLowerCase()===fn.headline.substring(0,40).toLowerCase();
    });
    if(!isDup)all.push(fn);
  });
  // Sort by datetime desc
  all.sort(function(a,b){return (b.datetime||0)-(a.datetime||0);});
  return all.slice(0,10);
}

async function fetchNews(ticker){
  // Fire all news sources simultaneously
  var results=await Promise.all([fetchFinnNews(ticker),fetchAVNews(ticker)]);
  var finnNews=results[0];
  var avResult=results[1];
  var merged=mergeNews(finnNews,avResult);
  // Attach overall sentiment metadata
  merged._overallSentiment=avResult.overallSentiment;
  merged._sentimentScore=avResult.sentimentScore;
  return merged;
}
function calcRSI(c,p){p=p||14;if(c.length<p+1)return null;var g=0,l=0;for(var i=1;i<=p;i++){var diff=c[i]-c[i-1];if(diff>=0)g+=diff;else l+=Math.abs(diff);}var ag=g/p,al=l/p;for(var i=p+1;i<c.length;i++){var diff=c[i]-c[i-1];var gn=diff>=0?diff:0,ln=diff<0?Math.abs(diff):0;ag=(ag*(p-1)+gn)/p;al=(al*(p-1)+ln)/p;}if(al===0)return 100;return+(100-(100/(1+ag/al))).toFixed(1);}
function calcVWAP(cv){if(!cv.length)return null;var ts=0,vs=0;cv.forEach(function(c){ts+=((c.h+c.l+c.c)/3)*c.v;vs+=c.v;});return vs>0?+(ts/vs).toFixed(2):null;}
function calcVolR(cv){if(cv.length<2)return null;var rec=cv[cv.length-1];var avg=cv.slice(0,-1).reduce(function(a,c){return a+c.v;},0)/(cv.length-1);return avg>0?+(rec.v/avg).toFixed(2):null;}
function calcHV(cv){if(cv.length<5)return null;var r=[];for(var i=1;i<cv.length;i++)if(cv[i-1].c>0)r.push(Math.abs((cv[i].c-cv[i-1].c)/cv[i-1].c)*100);if(!r.length)return null;return+(r.reduce(function(a,b){return a+b;},0)/r.length).toFixed(2);}
function calcMom(cv){if(cv.length<6)return null;return+((cv[cv.length-1].c-cv[cv.length-6].c)/cv[cv.length-6].c*100).toFixed(2);}
function detectPat(cv,rsi){if(!cv.length)return{name:"Unknown",desc:"No data"};var l=cv[cv.length-1],p=cv[cv.length-2]||l;var body=Math.abs(l.c-l.o),total=l.h-l.l,lower=Math.min(l.c,l.o)-l.l,upper=l.h-Math.max(l.c,l.o);if(lower>body*2&&upper<body*.5&&l.c>l.o)return{name:"Hammer 🔨",desc:"Bullish reversal"};if(body<total*.1)return{name:"Doji ⚡",desc:"Indecision — watch break"};if(l.c>p.h&&l.o<p.l)return{name:"Bull Engulf 🚀",desc:"Strong bullish reversal"};if(rsi&&rsi<55&&rsi>40&&total<(p.h-p.l)*.5)return{name:"Squeeze 🔥",desc:"Coiling for breakout"};if(l.c>p.h&&rsi&&rsi>55)return{name:"Breakout ↑",desc:"Breaking resistance"};if(cv.length>=5&&cv[cv.length-5].c<cv[cv.length-2].c&&body<total*.4)return{name:"Bull Flag 🏳",desc:"Continuation setup"};return l.c>l.o?{name:"Bullish Candle",desc:"Positive close"}:{name:"Bearish Candle",desc:"Negative close"};}
var PW=['surge','breakout','beat','contract','win','gain','rally','upgrade','buy','bullish','approval','launch','record','growth','strong'];
var NW=['loss','miss','drop','fall','decline','cut','sell','bearish','warning','lawsuit','downgrade','fail','dilut'];
function calcProb(rsi,vr,mom,nc,ns){var s=50;if(rsi!=null){if(rsi<30)s+=15;else if(rsi<45)s+=10;else if(rsi<60)s+=5;else if(rsi>70)s-=10;else if(rsi>80)s-=20;}if(vr!=null){if(vr>3)s+=15;else if(vr>2)s+=10;else if(vr>1.5)s+=5;else if(vr<.8)s-=10;}if(mom!=null){if(mom>10)s+=10;else if(mom>5)s+=5;else if(mom<-10)s-=15;else if(mom<-5)s-=8;}if(nc>3)s+=8;else if(nc>1)s+=4;if(ns==='positive')s+=8;else if(ns==='negative')s-=8;s=Math.max(20,Math.min(88,s));return{t1:Math.min(90,s+5),t2:Math.max(15,s-18),sl:Math.max(10,100-s-15),overall:s};}

async function runQuantAnalysis(ticker){
  var qStatusEl=document.getElementById('quant-status');
  if(qStatusEl)qStatusEl.textContent='LOADING DATA…';
  // Fire all data sources simultaneously
  var results=await Promise.all([
    fetchCandles(ticker),
    fetchNews(ticker),
    fetchStockfitOwnership(ticker),
    fetchStockfitDetails(ticker),
    fetchStockfitFinancials(ticker)
  ]);
  var candles=results[0],news=results[1],ownership=results[2],details=results[3],financials=results[4];
  var closes=candles.map(function(c){return c.c;});
  var rsi=calcRSI(closes),vwap=calcVWAP(candles),vr=calcVolR(candles),hv=calcHV(candles),mom=calcMom(candles),pat=detectPat(candles,rsi);
  var q=S.quotes[ticker];
  var vwapSpread=vwap&&q?+(((q.price-vwap)/vwap)*100).toFixed(2):null;
  var ht=news.map(function(n){return n.headline||'';}).join(' ').toLowerCase();
  var pc=PW.filter(function(w){return ht.indexOf(w)>=0;}).length;
  var nc=NW.filter(function(w){return ht.indexOf(w)>=0;}).length;
  // Incorporate Alpha Vantage AI sentiment score if available
  var avScore=news._sentimentScore;
  var sentiment;
  if(avScore!=null){
    sentiment=avScore>0.15?'positive':avScore<-0.15?'negative':'neutral';
    // Also boost pos/neg counts from AV
    if(avScore>0.15)pc+=3;else if(avScore<-0.15)nc+=3;
  } else {
    sentiment=pc>nc?'positive':nc>pc?'negative':'neutral';
  }
  var prob=calcProb(rsi,vr,mom,news.length,sentiment);
  S.quant[ticker]={rsi:rsi,vwap:vwap,vwapSpread:vwapSpread,volRatio:vr,histVol:hv,momentum:mom,pattern:pat,news:news,sentiment:sentiment,pc:pc,nc:nc,prob:prob,ownership:ownership,details:details,financials:financials};
  var rsiC=rsi==null?'var(--muted)':rsi<30?'var(--green)':rsi<55?'var(--green)':rsi<70?'var(--gold)':'var(--red)';
  var vrC=vr==null?'var(--muted)':vr>2?'var(--green)':vr>1.5?'var(--gold)':'var(--red)';
  var vwC=vwapSpread==null?'var(--muted)':vwapSpread>0?'var(--green)':vwapSpread>-3?'var(--gold)':'var(--red)';
  var mC=mom==null?'var(--muted)':mom>5?'var(--green)':mom>0?'var(--gold)':'var(--red)';
  if(qStatusEl)qStatusEl.textContent='LIVE DATA ✓';
  function setQ(id,val,col,sig){var el=document.getElementById(id);if(el){el.textContent=val;if(col)el.style.color=col;}var se=document.getElementById(id+'-s');if(se&&sig)se.textContent=sig;}
  setQ('q-rsi',rsi!=null?String(rsi):'N/A',rsiC,rsi==null?'No data':rsi<30?'OVERSOLD 🟢':rsi<45?'BULLISH RANGE 🟢':rsi<55?'NEUTRAL':rsi<70?'CAUTION 🟡':'OVERBOUGHT 🔴');
  setQ('q-vol',vr?vr+'x':'N/A',vrC,vr==null?'No data':vr>3?'3x AVG 🔥':vr>2?'2x AVG 🔥':vr>1.5?'Above avg ↑':'Below avg ↓');
  setQ('q-vwap',vwapSpread!=null?(vwapSpread>0?'+':'')+vwapSpread+'%':'N/A',vwC,vwap?'VWAP $'+vwap:'No data');
  setQ('q-mom',mom!=null?(mom>0?'+':'')+mom+'%':'N/A',mC,mom!=null?(mom>0?'Positive trend':'Negative trend'):'No data');
  var pe=document.getElementById('q-pat');if(pe){pe.textContent=pat.name;pe.style.color='var(--gold)';}
  var ps=document.getElementById('q-pat-s');if(ps)ps.textContent=pat.desc;
  var hve=document.getElementById('q-hv');if(hve){hve.textContent=hv?hv+'%':'N/A';hve.style.color=hv?(hv>5?'var(--orange)':hv>3?'var(--gold)':'var(--green)'):'var(--muted)';}
  var hvs=document.getElementById('q-hv-s');if(hvs)hvs.textContent=hv?(hv>5?'High volatility':hv>3?'Moderate':'Low volatility'):'No data';
  var ne=document.getElementById('news-container');
  if(ne){
    // Show AV overall sentiment banner if available
    var banner='';
    if(news._overallSentiment&&news._sentimentScore!=null){
      var osc=news._overallSentiment.toLowerCase().indexOf('bullish')>=0?'var(--green)':news._overallSentiment.toLowerCase().indexOf('bearish')>=0?'var(--red)':'var(--gold)';
      var scoreBar=Math.min(100,Math.max(0,Math.round((news._sentimentScore+1)/2*100)));
      banner='<div style="background:#050400;border:1px solid '+osc+'44;border-radius:6px;padding:8px 10px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center">'
        +'<div><div style="color:var(--muted);font-size:8px;letter-spacing:1px">MIDAS SENTIMENT SCORE</div>'
        +'<div style="color:'+osc+';font-size:13px;font-weight:bold;margin-top:2px">'+news._overallSentiment.toUpperCase()+'</div></div>'
        +'<div style="text-align:right"><div style="color:'+osc+';font-size:18px;font-weight:bold">'+news._sentimentScore.toFixed(2)+'</div>'
        +'<div style="color:var(--muted);font-size:8px">-1.0 Bearish → +1.0 Bullish</div></div>'
        +'</div>';
    }
    ne.innerHTML=banner+(news.length?news.map(function(n){
      var h=n.headline||'';
      // Use AV sentiment label if available, else keyword-based
      var sentLabel,sentColor,sentBg;
      if(n.sentiment){
        var sl2=n.sentiment.toLowerCase();
        if(sl2.indexOf('bullish')>=0){sentLabel='BULL';sentColor='var(--green)';sentBg='#00ff8822';}
        else if(sl2.indexOf('bearish')>=0){sentLabel='BEAR';sentColor='var(--red)';sentBg='#ff3b3b22';}
        else if(sl2.indexOf('somewhat')>=0&&sl2.indexOf('bullish')>=0){sentLabel='S-BULL';sentColor='var(--green)';sentBg='#00ff8811';}
        else if(sl2.indexOf('somewhat')>=0&&sl2.indexOf('bearish')>=0){sentLabel='S-BEAR';sentColor='var(--orange)';sentBg='#ff8c0022';}
        else{sentLabel='NEU';sentColor='var(--gold)';sentBg='#ffd70011';}
      } else {
        var ip=PW.some(function(w){return h.toLowerCase().indexOf(w)>=0;});
        var in2=NW.some(function(w){return h.toLowerCase().indexOf(w)>=0;});
        sentLabel=ip?'POS':in2?'NEG':'NEU';
        sentColor=ip?'var(--green)':in2?'var(--red)':'var(--gold)';
        sentBg=ip?'#00ff8822':in2?'#ff3b3b22':'#ffd70011';
      }
      var date=n.datetime?new Date(n.datetime*1000).toLocaleDateString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}):'';
      var srcBadge=n.feed==='AlphaVantage'?'<span style="color:var(--gold);font-size:7px;border:1px solid var(--gold-border);padding:0 4px;border-radius:2px;margin-left:4px">AV</span>':'';
      var relScore=n.relevanceScore!=null?'<span style="color:var(--muted);font-size:7px;margin-left:4px">rel:'+Math.round(n.relevanceScore*100)+'%</span>':'';
      var urlLink=n.url?'<a href="'+n.url+'" target="_blank" style="color:var(--gold);font-size:8px;margin-left:6px;text-decoration:none">→ READ</a>':'';
      return '<div class="news-item">'
        +'<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:6px">'
        +'<span style="color:var(--text);flex:1">'+h.substring(0,110)+(h.length>110?'…':'')+'</span>'
        +'<span style="background:'+sentBg+';color:'+sentColor+';font-size:8px;padding:1px 6px;border-radius:3px;white-space:nowrap;flex-shrink:0">'+sentLabel+'</span>'
        +'</div>'
        +'<div style="color:var(--muted);font-size:8px;margin-top:3px;display:flex;align-items:center;flex-wrap:wrap;gap:4px">'
        +(n.source||'')+srcBadge+relScore
        +'<span style="margin-left:auto">'+date+'</span>'
        +urlLink
        +'</div>'
        +'</div>';
    }).join(''):'<div style="color:var(--muted);font-size:10px;text-align:center;padding:10px">No recent news found</div>');
  }
  // Render Stockfit institutional data
  var instPanel=document.getElementById('institutional-panel');
  var instContent=document.getElementById('institutional-content');
  if(instPanel&&instContent&&(ownership||financials||details)){
    instPanel.style.display='block';
    var html='';
    // Company details
    if(details){
      if(details.marketCap){
        var mcStr=details.marketCap>=1e9?(details.marketCap/1e9).toFixed(2)+'B':details.marketCap>=1e6?(details.marketCap/1e6).toFixed(0)+'M':details.marketCap;
        html+='<div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="color:var(--muted);font-size:9px">Market Cap</span><span style="color:var(--gold);font-size:9px;font-weight:bold">$'+mcStr+'</span></div>';
      }
      if(details.employees) html+='<div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="color:var(--muted);font-size:9px">Employees</span><span style="color:var(--text);font-size:9px">'+details.employees.toLocaleString()+'</span></div>';
    }
    // Institutional ownership
    if(ownership){
      if(ownership.institutionalPct!=null){
        var instColor=ownership.institutionalPct>60?'var(--green)':ownership.institutionalPct>30?'var(--gold)':'var(--muted)';
        html+='<div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="color:var(--muted);font-size:9px">Institutional Ownership</span><span style="color:'+instColor+';font-size:9px;font-weight:bold">'+ownership.institutionalPct.toFixed(1)+'%</span></div>';
      }
      if(ownership.institutionalHolders) html+='<div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="color:var(--muted);font-size:9px">Institutional Holders</span><span style="color:var(--text);font-size:9px">'+ownership.institutionalHolders.toLocaleString()+'</span></div>';
      if(ownership.insiderCount) html+='<div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="color:var(--muted);font-size:9px">Insiders</span><span style="color:var(--text);font-size:9px">'+ownership.insiderCount+'</span></div>';
      if(ownership.topHolders&&ownership.topHolders.length){
        html+='<div style="color:var(--muted);font-size:8px;letter-spacing:1px;margin:8px 0 4px">TOP HOLDERS</div>';
        ownership.topHolders.forEach(function(h){
          var pct=h.pctOfShares?h.pctOfShares.toFixed(2)+'%':'';
          html+='<div style="display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid var(--gold-border);font-size:9px"><span style="color:var(--text);flex:1;margin-right:8px">'+h.managerName+'</span><span style="color:var(--gold)">'+pct+'</span></div>';
        });
      }
    }
    // Financial health
    if(financials){
      if(financials.healthScore!=null){
        var hColor=financials.healthScore>=70?'var(--green)':financials.healthScore>=40?'var(--gold)':'var(--red)';
        html+='<div style="display:flex;justify-content:space-between;margin:8px 0 4px"><span style="color:var(--muted);font-size:9px">Financial Health Score</span><span style="color:'+hColor+';font-size:11px;font-weight:bold">'+financials.healthScore+'/100</span></div>';
        html+='<div style="height:4px;background:var(--gold-border);border-radius:2px;overflow:hidden;margin-bottom:6px"><div style="width:'+Math.min(100,financials.healthScore)+'%;height:100%;background:'+hColor+';border-radius:2px"></div></div>';
      }
      if(financials.revenueGrowth!=null) html+='<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="color:var(--muted);font-size:9px">Revenue Growth</span><span style="color:'+(financials.revenueGrowth>0?'var(--green)':'var(--red)')+';font-size:9px">'+financials.revenueGrowth.toFixed(1)+'%</span></div>';
      if(financials.profitMargin!=null) html+='<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="color:var(--muted);font-size:9px">Profit Margin</span><span style="color:'+(financials.profitMargin>0?'var(--green)':'var(--red)')+';font-size:9px">'+financials.profitMargin.toFixed(1)+'%</span></div>';
      if(financials.cashPosition) html+='<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="color:var(--muted);font-size:9px">Cash Position</span><span style="color:var(--gold);font-size:9px">$'+(financials.cashPosition>=1e9?(financials.cashPosition/1e9).toFixed(2)+'B':(financials.cashPosition/1e6).toFixed(0)+'M')+'</span></div>';
    }
    instContent.innerHTML=html||'<div style="color:var(--muted);font-size:9px">Data not available for this ticker</div>';
  }

  // Boost probability if institutional ownership is high
  if(ownership&&ownership.institutionalPct>50){prob.t1=Math.min(92,prob.t1+4);prob.t2=Math.min(80,prob.t2+3);}

  setTimeout(function(){
    var ids=[['p-t1','pb-t1',prob.t1,'var(--green)'],['p-t2','pb-t2',prob.t2,'var(--gold)'],['p-sl','pb-sl',prob.sl,'var(--red)']];
    ids.forEach(function(x){var le=document.getElementById(x[0]);var be=document.getElementById(x[1]);if(le)le.textContent=x[2]+'%';if(be){be.style.width=x[2]+'%';be.style.background=x[3];}});
  },100);
}

// ── CARD RENDERING ─────────────────────────────────────────
function tagsHtml(tags){return(tags||[]).map(function(t){var c=TC[t]||'#555';return'<span class="tag" style="background:'+c+'33;border-color:'+c+'55;color:'+c+'">'+t+'</span>';}).join('');}
function priceBadgeHtml(q,qs,dualFeed){
  if(qs==='loading')return'<div class="fetching">FETCHING…</div>';
  if(qs==='error')return'<div style="color:var(--red);font-size:9px">NO DATA</div>';
  if(qs==='live'&&q){
    var srcCount=q.sourceCount||1;
    var badgeColor=q.confirmed?'var(--green)':'var(--gold)';
    var badgeText=q.confirmed?'✅ '+srcCount+' SOURCES AGREE':'⚠️ SPREAD '+q.spread+'%';
    var badge=dualFeed?'<div style="color:'+badgeColor+';font-size:7px;letter-spacing:0.5px">'+badgeText+'</div>':'<div style="color:var(--blue);font-size:7px">● '+q.source+'</div>';
    var mktState=q.marketState&&q.marketState!=='REGULAR'?'<div style="color:var(--orange);font-size:7px">'+q.marketState+'</div>':'';
    return'<div class="live-price">$'+q.price.toFixed(2)+'</div><div style="font-size:11px;font-weight:bold" class="'+(q.up?'up':'down')+'">'+q.change+'</div>'+mktState+badge;
  }
  return'<div style="color:#2a2000;font-size:9px">–</div>';
}

function renderCards(){
  if(!S.plays.length)return;
  var t=TIERS[CU&&CU.tier]||TIERS.free;
  var con=document.getElementById('cards-container');
  if(!con)return;
  con.innerHTML='';
  S.plays.slice(0,t.stockLimit).forEach(function(s,i){
    var q=S.quotes[s.ticker],qs=S.qStatus[s.ticker],lv=getLevels(s),ana=S.analysis[s.ticker],qd=S.quant[s.ticker];
    var inR=q?(q.price>=S.range.min&&q.price<S.range.max):true;
    var rc=RC[s.risk]||'#555';
    var cc=s.confidence>75?'var(--green)':s.confidence>60?'var(--gold)':'var(--red)';
    var levHtml=lv?('<div class="levels-grid"><div class="lbox"><div class="llab">ENTRY</div><div class="lval" style="color:#7dd3fc">$'+lv.en+'</div></div><div class="lbox"><div class="llab">STOP</div><div class="lval" style="color:var(--red)">$'+lv.sl+'</div></div><div class="lbox"><div class="llab">T1</div><div class="lval" style="color:var(--green)">$'+lv.t1+'</div></div><div class="lbox"><div class="llab">T2</div><div class="lval" style="color:var(--gold)">$'+lv.t2+'</div></div></div><div style="display:flex;justify-content:space-between;font-size:9px;margin-bottom:4px"><span style="color:var(--muted)">T1 <b style="color:var(--green)">+'+lv.p1+'%</b></span><span style="color:var(--muted)">T2 <b style="color:var(--gold)">+'+lv.p2+'%</b></span><span style="color:var(--muted)">SL <b style="color:var(--red)">-'+lv.pl+'%</b></span><div style="display:flex;align-items:center;gap:3px"><div style="width:44px;height:3px;background:var(--gold-border);border-radius:2px;overflow:hidden"><div style="width:'+s.confidence+'%;height:100%;background:'+cc+';border-radius:2px"></div></div><span style="color:var(--gold);font-size:9px">'+s.confidence+'%</span></div></div>'):'<div class="no-levels">LEVELS LOAD WITH LIVE QUOTE</div>';
    var qmini=qd&&t.quant?'<div class="qmini"><div class="qmbox"><div class="qmlab">RSI</div><div class="qmval" style="color:'+(qd.rsi<30?'var(--green)':qd.rsi<55?'var(--green)':qd.rsi<70?'var(--gold)':'var(--red)')+'">'+( qd.rsi||'–')+'</div></div><div class="qmbox"><div class="qmlab">VOL RATIO</div><div class="qmval" style="color:'+(qd.volRatio>2?'var(--green)':qd.volRatio>1.5?'var(--gold)':'var(--red)')+'">'+( qd.volRatio?qd.volRatio+'x':'–')+'</div></div><div class="qmbox"><div class="qmlab">T1 PROB</div><div class="qmval" style="color:var(--green)">'+( qd.prob?qd.prob.t1+'%':'–')+'</div></div></div>':'';
    var aib=ana?'<div class="ai-badge" style="background:'+(ana.verdict==='BUY NOW'?'#00ff88':ana.verdict==='WATCH'?'#ffd700':'#ff3b3b')+'11;border-color:'+(ana.verdict==='BUY NOW'?'#00ff88':ana.verdict==='WATCH'?'#ffd700':'#ff3b3b')+'44"><span style="color:'+(ana.verdict==='BUY NOW'?'#00ff88':ana.verdict==='WATCH'?'#ffd700':'#ff3b3b')+';font-weight:bold;font-size:10px;letter-spacing:2px">🤖 '+ana.verdict+'</span><span style="color:var(--gold);font-size:9px">'+ana.score+'/10</span></div>':'';
    var card=document.createElement('div');
    card.className='stock-card'+(S.selected&&S.selected.ticker===s.ticker?' selected':'')+((!inR&&q)?' out-of-range':'');
    card.style.animationDelay=(i*.06)+'s';
    card.onclick=function(){selectStock(s);};
    card.innerHTML='<div class="card-top"><div><span class="ticker-txt">$'+s.ticker+'</span><span class="sname">'+s.name+'</span></div><div class="price-box">'+priceBadgeHtml(q,qs,t.dualFeed)+'</div></div>'+(qs==='live'&&q?'<div class="ohlv"><span>O <b style="color:#94a3b8">$'+(q.open||'-')+'</b></span><span>H <b style="color:var(--green)">$'+(q.high||'-')+'</b></span><span>L <b style="color:var(--red)">$'+(q.low||'-')+'</b></span><span>VOL <b style="color:var(--gold)">'+fmtV(q.volume)+'</b></span>'+(!inR&&q?'<span style="color:var(--red);font-size:8px;margin-left:auto">⚠ OUT</span>':'')+'</div>':'')+'<div class="tags"><span class="tag" style="background:'+rc+'22;border-color:'+rc+'55;color:'+rc+'">'+s.risk+'</span><span class="tag" style="background:#1a1400;border-color:var(--gold-border);color:var(--gold)">'+s.timeframe+'</span>'+tagsHtml(s.tags)+'</div>'+levHtml+qmini+aib;
    con.appendChild(card);
  });
  if(S.plays.length>t.stockLimit){var nudge=document.createElement('div');nudge.style.cssText='margin-top:10px;text-align:center;padding:12px;background:var(--gold-bg);border:1px solid var(--gold)44;border-radius:8px';nudge.innerHTML='<div style="color:var(--gold);font-size:11px;font-weight:bold;margin-bottom:4px">🥇 '+(S.plays.length-t.stockLimit)+' more plays available</div><div style="color:var(--muted);font-size:9px;margin-bottom:8px">Upgrade to see all results</div><button onclick="showUpgrade()" style="background:var(--gold-bg);border:1px solid var(--gold);color:var(--gold);padding:6px 16px;border-radius:4px;cursor:pointer;font-family:inherit;font-size:9px">⚡ UPGRADE</button>';con.appendChild(nudge);}
}

// ── WATCHLIST ──────────────────────────────────────────────
function getWK(){return'midas_wl_'+(CU&&CU.username||'guest');}
function loadWatch(){S.watchlist=JSON.parse(localStorage.getItem(getWK())||'[]');}
function saveWatch(){localStorage.setItem(getWK(),JSON.stringify(S.watchlist));}
function addToWatch(ticker){
  var t=TIERS[CU&&CU.tier]||TIERS.free;
  if(t.watchLimit===0){showUpgrade();return;}
  ticker=ticker.toUpperCase().trim();
  if(S.watchlist.find(function(w){return w.ticker===ticker;})){showNotif('Already Watching','$'+ticker+' is already in your watchlist.');return;}
  if(S.watchlist.length>=t.watchLimit&&t.watchLimit<999){showNotif('Watchlist Full','Your '+t.name+' plan supports '+t.watchLimit+' stocks. Upgrade for unlimited.');showUpgrade();return;}
  var meta=POOL.find(function(p){return p.ticker===ticker;})||{ticker:ticker,name:ticker,sector:"Custom",tags:[],ep:-1.5,sp:-8,t1:12,t2:22};
  S.watchlist.push(Object.assign({},meta,{alertPrice:null,alertEnabled:false,addedAt:Date.now()}));
  saveWatch();renderWatchlist();showNotif('⚡ Added','$'+ticker+' added to MIDAS watchlist.');
}
function addWatchFromDetail(){if(!S.selected)return;var inW=S.watchlist.find(function(w){return w.ticker===S.selected.ticker;});if(inW){rmWatch(S.selected.ticker);return;}addToWatch(S.selected.ticker);updateDetailView();}
function rmWatch(t){S.watchlist=S.watchlist.filter(function(w){return w.ticker!==t;});saveWatch();renderWatchlist();if(S.selected&&S.selected.ticker===t)updateDetailView();}
async function refreshWatchlist(){
  if(!S.watchlist.length)return;
  var tickers=S.watchlist.map(function(w){return w.ticker;});
  tickers.forEach(function(t){S.qStatus[t]='loading';});renderWatchlist();
  await Promise.all(tickers.map(async function(t){var q=await fetchQuote(t);if(q){S.quotes[t]=q;S.qStatus[t]='live';}else S.qStatus[t]='error';}));
  renderWatchlist();checkAlerts();
}
function startWatchMonitor(){if(S.watchTimer)clearInterval(S.watchTimer);S.watchTimer=setInterval(function(){if(S.watchlist.length)refreshWatchlist();},60000);if(S.watchlist.length)refreshWatchlist();}
async function checkAlerts(){
  var t=TIERS[CU&&CU.tier]||TIERS.free;if(!t.alerts)return;
  for(var i=0;i<S.watchlist.length;i++){
    var w=S.watchlist[i];
    if(!w.alertEnabled||!w.alertPrice)continue;
    var q=S.quotes[w.ticker];if(!q)continue;
    if(q.price<=w.alertPrice){
      var last=w.lastAlert||(Date.now()-999999);
      if(Date.now()-last<300000)continue;
      if(t.ai){
        try{var r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:200,system:'Day trader AI. Respond ONLY with JSON: {"verdict":"BUY NOW","reason":"one sentence"} or WATCH or AVOID.',messages:[{role:'user',content:w.ticker+' price $'+q.price+' '+q.change+'. Alert at $'+w.alertPrice+'. Quick verdict?'}]})});var d=await r.json();var raw=d.content&&d.content.find(function(b){return b.type==='text';});var res=raw?JSON.parse(raw.text.replace(/```json|```/g,'').trim()):{};showNotif((res.verdict==='BUY NOW'?'🚨 BUY':'🔔 MIDAS ALERT')+' — $'+w.ticker,'$'+q.price+' hit alert $'+w.alertPrice+(res.reason?'. AI: '+res.reason:''));}catch(e){showNotif('🔔 MIDAS ALERT — $'+w.ticker,'Price $'+q.price+' reached your alert of $'+w.alertPrice);}
      }else{showNotif('🔔 MIDAS ALERT — $'+w.ticker,'Price $'+q.price+' reached your alert of $'+w.alertPrice);}
      w.lastAlert=Date.now();saveWatch();
    }
  }
}
function renderWatchlist(){
  var t=TIERS[CU&&CU.tier]||TIERS.free;
  var gEl=document.getElementById('watch-gate');
  var emEl=document.getElementById('watch-empty');
  var cEl=document.getElementById('watch-cards');
  var cnEl=document.getElementById('watch-count');
  if(!gEl)return;
  if(t.watchLimit===0){gEl.innerHTML='';showGate('bronze','Watchlist & Price Alerts','watch-gate');if(emEl)emEl.style.display='none';if(cEl)cEl.innerHTML='';return;}
  gEl.innerHTML='';
  if(cnEl)cnEl.textContent=S.watchlist.length+(t.watchLimit<999?'/'+t.watchLimit:'')+' stock'+(S.watchlist.length===1?'':'s')+' monitored';
  if(!S.watchlist.length){if(emEl)emEl.style.display='block';if(cEl)cEl.innerHTML='';return;}
  if(emEl)emEl.style.display='none';
  if(!cEl)return;
  cEl.innerHTML='';
  S.watchlist.forEach(function(w,i){
    var q=S.quotes[w.ticker],qs=S.qStatus[w.ticker];
    var alerted=w.lastAlert&&(Date.now()-w.lastAlert)<300000;
    var card=document.createElement('div');
    card.className='watch-card'+(alerted?' alerted':'');
    card.style.animationDelay=(i*.06)+'s';
    var ps=qs==='loading'?'<div class="fetching">FETCHING…</div>':qs==='live'&&q?'<div class="live-price">$'+q.price.toFixed(2)+'</div><div style="font-size:11px;font-weight:bold" class="'+(q.up?'up':'down')+'">'+q.change+'</div><div style="color:var(--blue);font-size:7px">● LIVE</div>':'<div style="color:var(--red);font-size:9px">'+(qs==='error'?'NO DATA':'–')+'</div>';
    card.innerHTML='<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px"><div><div><span class="ticker-txt">$'+w.ticker+'</span><span class="sname">'+w.name+'</span></div><div style="color:var(--muted);font-size:9px;margin-top:2px">'+w.sector+'</div>'+(alerted?'<div style="background:#00ff8822;border:1px solid #00ff8866;color:var(--green);font-size:9px;padding:2px 8px;border-radius:4px;margin-top:4px;display:inline-block">🚨 BUY SIGNAL</div>':'')+'</div><div style="text-align:right">'+ps+'<button onclick="rmWatch(\''+w.ticker+'\')" style="margin-top:6px;background:transparent;border:1px solid #ff3b3b44;color:var(--red);font-size:9px;padding:2px 8px;border-radius:4px;cursor:pointer;font-family:inherit;display:block">✕ REMOVE</button></div></div>'+(qs==='live'&&q?'<div class="ohlv" style="margin-bottom:6px"><span>H <b style="color:var(--green)">$'+(q.high||'-')+'</b></span><span>L <b style="color:var(--red)">$'+(q.low||'-')+'</b></span><span>VOL <b style="color:var(--gold)">'+fmtV(q.volume)+'</b></span></div>':'')+'<div class="alert-settings"><span style="color:var(--muted);font-size:9px">🔔 ALERT $</span><input class="alert-input" type="number" placeholder="0.00" step="0.01" value="'+(w.alertPrice||'')+'" onchange="updAlert(\''+w.ticker+'\',this.value,document.getElementById(\'tog_'+w.ticker+'\').classList.contains(\'on\'))"/><button class="alert-toggle '+(w.alertEnabled?'on':'')+'" id="tog_'+w.ticker+'" onclick="togAlert(\''+w.ticker+'\',this)">'+(w.alertEnabled?'🔔 ON':'🔕 OFF')+'</button><button onclick="openAna(\''+w.ticker+'\')" style="background:transparent;border:1px solid #3a1a6a;color:var(--purple);font-size:9px;padding:2px 8px;border-radius:4px;cursor:pointer;font-family:inherit">🧠 ANALYZE</button></div>';
    cEl.appendChild(card);
  });
}
function updAlert(t,p,e){var w=S.watchlist.find(function(w){return w.ticker===t;});if(!w)return;w.alertPrice=p?parseFloat(p):null;w.alertEnabled=e;saveWatch();}
function togAlert(t,btn){var w=S.watchlist.find(function(w){return w.ticker===t;});if(!w)return;w.alertEnabled=!w.alertEnabled;btn.className='alert-toggle'+(w.alertEnabled?' on':'');btn.textContent=w.alertEnabled?'🔔 ON':'🔕 OFF';var inp=btn.parentElement.querySelector('.alert-input');w.alertPrice=inp&&inp.value?parseFloat(inp.value):null;saveWatch();}
function openAna(t){var m=POOL.find(function(p){return p.ticker===t;})||{ticker:t,name:t,sector:"Custom",tags:[],ep:-1.5,sp:-8,t1:12,t2:22};selectStock(m);}

// ── CRYPTO ─────────────────────────────────────────────────
async function loadCrypto(){
  var t=TIERS[CU&&CU.tier]||TIERS.free;
  var gEl=document.getElementById('crypto-gate');
  var hEl=document.getElementById('crypto-header');
  if(!t.crypto){if(gEl)gEl.innerHTML='';showGate('silver','Crypto Scanner','crypto-gate');if(hEl)hEl.style.display='none';document.getElementById('crypto-cards').innerHTML='';return;}
  if(gEl)gEl.innerHTML='';
  if(hEl)hEl.style.display='flex';
  var loadEl=document.getElementById('crypto-loading');
  if(loadEl)loadEl.style.display='block';
  document.getElementById('crypto-cards').innerHTML='';
  await Promise.all(CRYPTOS.map(async function(c){try{var r=await fetch('https://finnhub.io/api/v1/quote?symbol='+c.sym+'&token='+FINN);var d=await r.json();if(d&&d.c&&d.c>0){var chg=d.pc>0?((d.c-d.pc)/d.pc)*100:0;S.cryptoQ[c.code]={price:d.c,change:(chg>=0?'+':'')+chg.toFixed(2)+'%',up:chg>=0,chgPct:chg};}}catch(e){}}));
  if(loadEl)loadEl.style.display='none';
  renderCrypto();
}
function renderCrypto(){
  var con=document.getElementById('crypto-cards');if(!con)return;con.innerHTML='';
  ['Major','Meme','Alt'].forEach(function(type){
    var items=CRYPTOS.filter(function(c){return c.type===type;});if(!items.length)return;
    var h=document.createElement('div');h.style.cssText='color:var(--muted);font-size:9px;letter-spacing:2px;margin:12px 0 6px;padding-bottom:4px;border-bottom:1px solid var(--gold-border)';h.textContent={Major:'🏆 MAJOR',Meme:'🐸 MEME COINS',Alt:'⚡ ALTCOINS'}[type];con.appendChild(h);
    items.forEach(function(c,i){
      var q=S.cryptoQ[c.code];var sig='NEUTRAL',sc='var(--muted)';
      if(q){if(q.chgPct>5){sig='HOT 🔥';sc='var(--green)';}else if(q.chgPct>2){sig='BULLISH ↑';sc='var(--green)';}else if(q.chgPct<-5){sig='DUMP ⚠️';sc='var(--red)';}else if(q.chgPct<-2){sig='BEARISH ↓';sc='var(--orange)';}}
      var card=document.createElement('div');card.className='crypto-card';card.style.animationDelay=(i*.05)+'s';
      card.innerHTML='<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px"><div><div style="color:var(--gold);font-weight:bold;font-size:15px">'+c.code+' <span style="color:var(--muted);font-size:10px;font-weight:normal">/ USDT</span></div><div style="color:var(--muted);font-size:9px">'+c.name+' • '+c.type+'</div><div class="tags" style="margin-top:5px">'+tagsHtml(c.tags)+'</div></div><div style="text-align:right"><div style="color:#fff;font-weight:bold;font-size:16px">'+(q?fmtP(q.price):'LOADING…')+'</div><div style="font-size:12px;font-weight:bold" class="'+(q&&q.up?'up':'down')+'">'+(q&&q.change||'–')+'</div><div style="color:var(--blue);font-size:7px;letter-spacing:1px;margin-top:2px">● FINNHUB</div></div></div><div style="display:flex;justify-content:space-between;align-items:center"><span style="background:'+sc+'22;border:1px solid '+sc+'55;color:'+sc+';padding:2px 8px;border-radius:4px;font-size:9px;font-weight:bold">'+sig+'</span><button onclick="addToWatch(\''+c.code+'\')" style="background:transparent;border:1px solid #00ff8844;color:var(--green);font-size:9px;padding:2px 8px;border-radius:4px;cursor:pointer;font-family:inherit">+ WATCH</button></div>';
      con.appendChild(card);
    });
  });
}

// ── NOTIFICATIONS ──────────────────────────────────────────
var notifT=null;
function showNotif(title,text){
  var tEl=document.getElementById('an-title'),txEl=document.getElementById('an-text'),nEl=document.getElementById('alert-notif');
  if(!tEl||!nEl)return;
  tEl.textContent=title;txEl.textContent=text;nEl.style.display='block';
  if(notifT)clearTimeout(notifT);
  notifT=setTimeout(function(){nEl.style.display='none';},7000);
  try{if(navigator.vibrate)navigator.vibrate([200,100,200]);}catch(e){}
}

// ── SELECT + DETAIL ────────────────────────────────────────
function selectStock(stock){
  S.selected=stock;showTab('detail');updateDetailView();
  var t=TIERS[CU&&CU.tier]||TIERS.free;
  var aiBox=document.getElementById('ai-box');
  var dgate=document.getElementById('detail-gate');
  var qpanel=document.getElementById('quant-panel');
  if(dgate)dgate.innerHTML='';
  if(qpanel)qpanel.style.display='none';
  if(!t.ai){
    if(aiBox)aiBox.innerHTML='<div class="gate-banner"><div style="font-size:24px;margin-bottom:8px">🤖</div><div style="color:var(--bronze);font-size:12px;font-weight:bold;margin-bottom:4px">BRONZE REQUIRED</div><div style="color:var(--muted);font-size:9px;margin-bottom:10px">AI analysis requires Bronze ($5/mo)</div><button style="padding:8px 16px;border-radius:4px;cursor:pointer;font-family:inherit;font-size:9px;background:var(--bronze-bg);border:1px solid var(--bronze);color:var(--bronze)" onclick="showUpgrade()">⚡ UPGRADE</button></div>';
  } else {
    if(aiBox)aiBox.innerHTML='<div style="color:var(--gold);font-size:9px;letter-spacing:2px;margin-bottom:8px">🤖 MIDAS AI — DEEP ANALYSIS</div><div id="ai-content"><div style="text-align:center;padding:12px"><button style="background:linear-gradient(135deg,#4a1d96,#7c3aed);border:none;color:white;padding:10px 22px;border-radius:6px;cursor:pointer;font-size:11px;letter-spacing:2px;font-family:inherit" onclick="runDeepAnalysis()">🧠 RUN MIDAS AI ANALYSIS</button><div style="color:var(--muted);font-size:9px;margin-top:8px">RSI + Volume + News + Price History → Claude AI</div></div></div>';
    var ana=S.analysis[stock.ticker];if(ana)renderAI('result',ana);
  }
  if(t.quant){if(qpanel)qpanel.style.display='block';runQuantAnalysis(stock.ticker);}
  else if(t.ai&&!t.quant){if(dgate)showGate('gold','Quant Analysis (RSI, VWAP, Pattern, Probability)','detail-gate');}
  if(!S.quotes[stock.ticker]){
    S.qStatus[stock.ticker]='loading';
    fetchQuote(stock.ticker).then(function(q){if(q){S.quotes[stock.ticker]=q;S.qStatus[stock.ticker]='live';}else S.qStatus[stock.ticker]='error';updateDetailPrices();});
  }
}

function updateDetailPrices(){
  if(!S.selected)return;
  var s=S.selected,q=S.quotes[s.ticker],qs=S.qStatus[s.ticker],lv=getLevels(s);
  var pEl=document.getElementById('d-price');
  var cEl=document.getElementById('d-change');
  var lbEl=document.getElementById('d-live-badge');
  var ohlvEl=document.getElementById('d-ohlv');
  if(qs==='live'&&q){
    if(pEl){pEl.textContent='$'+q.price.toFixed(2);pEl.style.color='#fff';pEl.style.fontSize='26px';}
    if(cEl){cEl.textContent=q.change||'—';cEl.className=q.up?'up':'down';}
    if(lbEl){
    if(q.sourceCount>=2){
      lbEl.textContent=q.confirmed?'✅ '+q.sourceCount+' SOURCES CONFIRMED':'⚠️ '+q.sourceCount+' SOURCES SPREAD '+q.spread+'%';
      lbEl.style.color=q.confirmed?'var(--green)':'var(--gold)';
    }else{
      lbEl.textContent='● LIVE ('+q.source+')';
      lbEl.style.color='var(--blue)';
    }
    if(q.allSources){
      var asEl=document.getElementById('d-all-sources');
      if(asEl)asEl.textContent=q.allSources;
    }
  }
    if(ohlvEl)ohlvEl.style.display='flex';
    var ids=[['d-open',q.open,'#94a3b8'],['d-high',q.high,'var(--green)'],['d-low',q.low,'var(--red)'],['d-pc',q.prevClose,'var(--gold)'],['d-vol',null,'var(--gold)']];
    ids.forEach(function(x){var el=document.getElementById(x[0]);if(el){el.style.color=x[2];el.textContent=x[1]?(x[0]==='d-vol'?fmtV(x[1]):'$'+x[1]):fmtV(q.volume);}});
    var volEl=document.getElementById('d-vol');if(volEl)volEl.textContent=fmtV(q.volume);
  }else if(qs==='loading'){if(pEl){pEl.textContent='FETCHING…';pEl.style.color='var(--gold)';pEl.style.fontSize='14px';}}
  if(lv){['d-entry','d-stop','d-t1','d-t2','d-p1','d-p2','d-pl'].forEach(function(id,i){var el=document.getElementById(id);if(!el)return;var vals=['$'+lv.en,'$'+lv.sl,'$'+lv.t1,'$'+lv.t2,'+'+lv.p1+'%','+'+lv.p2+'%','-'+lv.pl+'%'];el.textContent=vals[i];});}
}

function updateDetailView(){
  var s=S.selected;if(!s)return;
  var ids=[['d-ticker','$'+s.ticker],['d-name',s.name],['d-sector',s.sector],['d-catalyst',CATS[s.ticker]||s.catalyst||s.why||'Momentum setup — run MIDAS analysis for full breakdown.']];
  ids.forEach(function(x){var el=document.getElementById(x[0]);if(el)el.textContent=x[1];});
  var inW=S.watchlist.find(function(w){return w.ticker===s.ticker;});
  var btn=document.getElementById('add-watch-btn');
  if(btn){btn.textContent=inW?'✅ IN WATCHLIST — TAP TO REMOVE':'+ WATCH THIS STOCK';btn.style.borderColor=inW?'#ff3b3b66':'var(--gold)';btn.style.color=inW?'var(--red)':'var(--gold)';}
  updateDetailPrices();
}

// ── AI ANALYSIS ────────────────────────────────────────────
function renderAI(mode,data){
  var el=document.getElementById('ai-content');if(!el)return;
  if(mode==='loading'){
    el.innerHTML='<div style="text-align:center;padding:18px 0"><div style="color:var(--gold);font-size:11px;letter-spacing:2px">MIDAS AI THINKING DEEPLY…</div><div style="color:var(--muted);font-size:9px;margin-top:4px">RSI + Volume + News + Price History → Claude AI</div><div style="display:flex;justify-content:center;gap:5px;margin-top:10px"><div class="ai-dot"></div><div class="ai-dot"></div><div class="ai-dot"></div><div class="ai-dot"></div><div class="ai-dot"></div></div></div>';
  }else if(mode==='prompt'){
    el.innerHTML='<div style="text-align:center;padding:12px"><button style="background:linear-gradient(135deg,#4a1d96,#7c3aed);border:none;color:white;padding:10px 22px;border-radius:6px;cursor:pointer;font-size:11px;letter-spacing:2px;font-family:inherit" onclick="runDeepAnalysis()">🧠 RUN MIDAS AI ANALYSIS</button></div>';
  }else if(mode==='result'&&data){
    var vc=data.verdict==='BUY NOW'?'var(--green)':data.verdict==='WATCH'?'var(--gold)':'var(--red)';
    var dots='';for(var i=0;i<10;i++)dots+='<div style="width:8px;height:8px;border-radius:2px;background:'+(i<(data.score||0)?'var(--gold)':'#2a1a00')+'"></div>';
    var pr=data.prob_t1!=null?'<div style="display:flex;gap:8px;margin-bottom:10px;padding:8px;background:#050400;border-radius:6px;border:1px solid var(--gold-border);text-align:center"><div style="flex:1"><div style="color:var(--muted);font-size:8px">T1 PROB</div><div style="color:var(--green);font-size:16px;font-weight:bold">'+data.prob_t1+'%</div></div><div style="flex:1"><div style="color:var(--muted);font-size:8px">T2 PROB</div><div style="color:var(--gold);font-size:16px;font-weight:bold">'+data.prob_t2+'%</div></div><div style="flex:1"><div style="color:var(--muted);font-size:8px">STOP PROB</div><div style="color:var(--red);font-size:16px;font-weight:bold">'+data.prob_sl+'%</div></div><div style="flex:1"><div style="color:var(--muted);font-size:8px">OVERALL</div><div style="color:var(--purple);font-size:16px;font-weight:bold">'+data.overall_score+'%</div></div></div>':'';
    var sects=[['SETUP QUALITY',data.setup_quality],['THE EDGE',data.edge],['KEY LEVELS',data.key_levels],['INTRADAY PLAN',data.intraday_plan],['EXIT RULES',data.exit_rules],['NEWS IMPACT',data.news_impact]];
    var sectHtml='';sects.forEach(function(x){if(x[1])sectHtml+='<div style="color:var(--gold);font-size:8px;letter-spacing:2px;margin-bottom:4px;margin-top:8px">'+x[0]+'</div><div style="color:#c8b870;font-size:11px;line-height:1.7">'+x[1]+'</div>';});
    var rfHtml='';if(data.risk_factors&&data.risk_factors.length){rfHtml='<div style="color:var(--gold);font-size:8px;letter-spacing:2px;margin-top:8px;margin-bottom:4px">⚠️ RISK FACTORS</div>';data.risk_factors.forEach(function(r){rfHtml+='<div style="color:#ff9999;font-size:10px;padding:3px 0;border-bottom:1px solid #2a1a00">• '+r+'</div>';});}
    el.innerHTML='<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:'+vc+'15;border:1px solid '+vc+'44;border-radius:6px;margin-bottom:10px"><span style="color:'+vc+';font-size:15px;font-weight:bold;letter-spacing:2px">'+data.verdict+'</span><div style="display:flex;gap:2px">'+dots+'</div></div>'+pr+sectHtml+rfHtml;
  }
}

async function runDeepAnalysis(){
  var t=TIERS[CU&&CU.tier]||TIERS.free;if(!t.ai){showUpgrade();return;}
  if(!S.selected)return;
  var s=S.selected,q=S.quotes[s.ticker],lv=getLevels(s),qd=S.quant[s.ticker];
  renderAI('loading');
  var nH=qd&&qd.news?qd.news.slice(0,5).map(function(n){return n.headline;}).join(' | '):'No recent news';
  var avSentStr=qd&&qd.news&&qd.news._overallSentiment?('AV Overall: '+qd.news._overallSentiment+' (score '+qd.news._sentimentScore+')'):'';
  var sfStr='';
  if(qd&&qd.ownership) sfStr+='InstOwnership:'+qd.ownership.institutionalPct+'% ('+qd.ownership.institutionalHolders+' holders) | ';
  if(qd&&qd.financials) sfStr+='HealthScore:'+qd.financials.healthScore+'/100 | RevGrowth:'+qd.financials.revenueGrowth+'% | CashPos:$'+(qd.financials.cashPosition?(qd.financials.cashPosition/1e6).toFixed(0)+'M':'N/A');
  var qctx=qd?'RSI:'+qd.rsi+' | VolRatio:'+qd.volRatio+'x | VWAPspread:'+qd.vwapSpread+'% | 5dMom:'+qd.momentum+'% | Pattern:'+qd.pattern.name+' | HistVol:'+qd.histVol+'% | Sentiment:'+qd.sentiment+'('+qd.pc+'pos/'+qd.nc+'neg) | '+avSentStr+' | T1prob:'+qd.prob.t1+'% | '+sfStr+' | Headlines:'+nH:'No quant data loaded.';
  try{
    var r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
      model:'claude-sonnet-4-20250514',
      max_tokens:1500,
      system:'You are MIDAS AI — an elite quantitative penny stock analyst. You provide deep, data-driven trading analysis using all available quantitative metrics. Analyze RSI levels in context of the current price trend, whether volume ratio indicates smart money accumulation or distribution, how the technical pattern historically resolves, news sentiment alignment with the technical setup, and historical volatility for position sizing. Return ONLY valid JSON: {"verdict":"BUY NOW"|"WATCH"|"AVOID","score":1-10,"prob_t1":integer,"prob_t2":integer,"prob_sl":integer,"overall_score":integer,"setup_quality":"3 sentences on setup quality","edge":"3 sentences on the specific trading edge","key_levels":"specific price levels to watch","intraday_plan":"step-by-step execution plan","exit_rules":"specific conditional exits","news_impact":"how news affects this trade","risk_factors":["5 specific data-driven risks"]}',
      messages:[{role:'user',content:'MIDAS DEEP ANALYSIS\n\nTicker: '+s.ticker+' ('+s.name+') — '+s.sector+'\nLive: $'+(q&&q.price||'?')+' | Change: '+(q&&q.change||'?')+' | Vol: '+fmtV(q&&q.volume)+'\nOHLC: O$'+(q&&q.open||'?')+' H$'+(q&&q.high||'?')+' L$'+(q&&q.low||'?')+' PC$'+(q&&q.prevClose||'?')+'\nEntry:$'+(lv&&lv.en||'?')+' Stop:$'+(lv&&lv.sl||'?')+' T1:$'+(lv&&lv.t1||'?')+' T2:$'+(lv&&lv.t2||'?')+'\nCatalyst: '+(CATS[s.ticker]||'')+'\n\nQUANT DATA:\n'+qctx+'\n\nMacro: Risk-on rally, IWM +2.1%, defense AI hot, small-caps ripping.\n\nProvide your highest-conviction data-driven analysis. Return ONLY JSON.'}]
    })});
    var d=await r.json();
    var raw=d.content&&d.content.find(function(b){return b.type==='text';});
    var parsed=raw?JSON.parse(raw.text.replace(/```json|```/g,'').trim()):{};
    S.analysis[s.ticker]=parsed;renderAI('result',parsed);renderCards();
  }catch(e){
    var fb={verdict:'WATCH',score:5,prob_t1:55,prob_t2:35,prob_sl:25,overall_score:55,setup_quality:'Review quantitative metrics above before entry. RSI and volume ratio are the key indicators for this setup.',edge:'Verify catalyst alignment with technical setup. Volume confirmation is essential for high-probability entries.',key_levels:'Use VWAP as dynamic support and resistance. Entry zone and stop levels are based on live price.',intraday_plan:'Wait for price to hold entry zone for at least 2 candles with supporting volume before entering.',exit_rules:'Scale out 50% at Target 1. Trail stop on remainder. Full exit if hard stop is breached.',news_impact:'Review recent headlines in the news section. Positive sentiment increases probability of success.',risk_factors:['Confirm live price before entry','Reduce position size in uncertain conditions','Set hard stop loss immediately upon fill','Monitor volume — fading volume means exit early','Have exit plan ready before entry']};
    S.analysis[s.ticker]=fb;renderAI('result',fb);
  }
}

// ── PROFILE ────────────────────────────────────────────────
function renderProfile(){
  if(!CU)return;
  var t=TIERS[CU.tier]||TIERS.free;
  var pn=document.getElementById('prof-name');if(pn)pn.textContent=CU.username;
  var pt=document.getElementById('prof-tier');
  if(pt){pt.textContent=(t.icon?t.icon+' ':'')+t.name;pt.style.color=t.color;pt.style.borderColor=t.border;pt.style.background=t.bg;}
  var pe=document.getElementById('prof-exp');
  if(pe){if(CU.expiry){var d=new Date(CU.expiry);pe.textContent='Expires: '+d.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});}else pe.textContent=CU.tier==='free'?'Free plan — upgrade anytime':CU.tier==='admin'?'👑 Admin — full access':'Active subscription';}
  var fl=document.getElementById('feature-list');
  if(fl){var feats=[{l:t.stockLimit+' stock scan results',h:true},{l:'Live dual-feed (Polygon + Finnhub)',h:t.dualFeed},{l:'Watchlist ('+(t.watchLimit>=999?'unlimited':t.watchLimit+' stocks')+')',h:t.watchLimit>0},{l:'Price alerts & notifications',h:t.alerts},{l:'AI verdict (BUY/WATCH/AVOID)',h:!!t.ai},{l:'Full MIDAS AI deep analysis',h:t.ai===true},{l:'Crypto scanner',h:t.crypto},{l:'RSI + VWAP + Volume quant',h:t.quant},{l:'Pattern recognition',h:t.quant},{l:'Probability forecasting',h:t.quant},{l:'News sentiment feed',h:t.quant},{l:'Admin panel',h:CU.tier==='admin'}];fl.innerHTML=feats.map(function(f){return'<div class="feature-item"><span>'+(f.h?'✅':'❌')+'</span><span style="color:'+(f.h?'var(--text)':'var(--muted)')+(f.h?'':';text-decoration:line-through')+'">'+f.l+'</span></div>';}).join('');}
}

// ── ADMIN ──────────────────────────────────────────────────
var editingUser=null;
function renderAdmin(){
  var users=getUsers();
  var ce=document.getElementById('admin-count');if(ce)ce.textContent=users.length+' user'+(users.length===1?'':'s')+' registered';
  var list=document.getElementById('user-list');if(!list)return;
  list.innerHTML=users.map(function(u){
    var t=TIERS[u.tier]||TIERS.free;
    var exp=u.expiry?new Date(u.expiry).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}):'No expiry';
    var isAdmin=u.username==='Rharter';
    return'<div class="user-row"><div style="flex:1"><div style="color:var(--text);font-size:12px;font-weight:bold">'+u.username+(isAdmin?' <span style="color:var(--admin);font-size:9px">ADMIN</span>':'')+'</div><div style="color:'+t.color+';font-size:9px;margin-top:2px">'+(t.icon?t.icon+' ':'')+t.name+' • '+t.price+'</div><div style="color:var(--muted);font-size:8px;margin-top:1px">Exp: '+exp+' • Joined: '+new Date(u.createdAt||Date.now()).toLocaleDateString()+'</div></div><div style="display:flex;gap:6px">'+(isAdmin?'':'<button style="padding:3px 8px;border-radius:4px;cursor:pointer;font-size:8px;font-family:inherit;background:var(--gold-bg);border:1px solid var(--gold-border);color:var(--gold)" onclick="adminEdit(\''+u.username+'\')">✏️ EDIT</button><button style="padding:3px 8px;border-radius:4px;cursor:pointer;font-size:8px;font-family:inherit;background:#1a0808;border:1px solid #ff3b3b44;color:var(--red)" onclick="adminDel(\''+u.username+'\')">✕</button>')+'</div></div>';
  }).join('');
}
function toggleAddForm(){var f=document.getElementById('add-form');if(f)f.style.display=f.style.display==='none'?'block':'none';}
function adminAdd(){
  var u=document.getElementById('nu-user').value.trim();
  var p=document.getElementById('nu-pass').value;
  var tier=document.getElementById('nu-tier').value;
  var exp=document.getElementById('nu-exp').value;
  var err=document.getElementById('add-err');
  if(!u||!p){err.textContent='Username and password required';return;}
  if(findUser(u)){err.textContent='Username already exists';return;}
  var users=getUsers();users.push({username:u,password:p,tier:tier,expiry:exp||null,createdAt:Date.now()});saveUsers(users);
  document.getElementById('nu-user').value='';document.getElementById('nu-pass').value='';document.getElementById('nu-exp').value='';
  err.style.color='var(--gold)';err.textContent='✅ '+u+' created';
  setTimeout(function(){if(err)err.textContent='';},2000);
  renderAdmin();
}
function adminEdit(username){
  editingUser=username;
  var u=findUser(username);if(!u)return;
  document.getElementById('edit-name').textContent=username;
  document.getElementById('edit-tier').value=u.tier;
  document.getElementById('edit-exp').value=u.expiry||'';
  document.getElementById('edit-pass').value='';
  var ep=document.getElementById('edit-panel');if(ep)ep.style.display='block';
}
function adminSave(){
  if(!editingUser)return;
  var users=getUsers();var idx=users.findIndex(function(u){return u.username===editingUser;});if(idx===-1)return;
  users[idx].tier=document.getElementById('edit-tier').value;
  users[idx].expiry=document.getElementById('edit-exp').value||null;
  var np=document.getElementById('edit-pass').value;if(np)users[idx].password=np;
  saveUsers(users);
  var ep=document.getElementById('edit-panel');if(ep)ep.style.display='none';
  showNotif('⚡ Updated',editingUser+' has been updated.');
  editingUser=null;renderAdmin();
}
function adminDel(username){
  if(username==='Rharter'){showNotif('Cannot Delete','Admin account cannot be deleted.');return;}
  if(!window.confirm('Delete user '+username+'? This cannot be undone.'))return;
  saveUsers(getUsers().filter(function(u){return u.username!==username;}));
  renderAdmin();showNotif('Deleted',username+' has been removed.');
}

// ── AI SCAN ────────────────────────────────────────────────
var SMSGS=["Awakening MIDAS AI…","Filtering by price range…","Analyzing catalysts…","Scanning sector momentum…","Fetching live quotes…","Running MIDAS quant screen…","Ranking by golden conviction…","MIDAS plays locked ✓"];
async function runScan(){
  if(S.scanning)return;
  S.scanning=true;S.selected=null;S.analysis={};S.quant={};
  var sdot=document.getElementById('status-dot');if(sdot)sdot.className='dot scanning';
  var sbtn=document.getElementById('scan-btn');if(sbtn)sbtn.className='scan-btn scanning';
  var es=document.getElementById('empty-state');if(es)es.style.display='none';
  var so=document.getElementById('scan-overlay');if(so)so.style.display='block';
  var cc=document.getElementById('cards-container');if(cc)cc.innerHTML='';
  var pn=document.getElementById('poly-note');if(pn)pn.style.display='none';
  var rb=document.getElementById('ref-btn');if(rb)rb.style.display='none';
  var pv=0,mi=0;
  var iv=setInterval(function(){
    pv=Math.min(pv+2,88);
    var ni=Math.floor((pv/88)*(SMSGS.length-1));
    if(ni!==mi){mi=ni;var sm=document.getElementById('scan-msg');if(sm)sm.textContent=SMSGS[ni];}
    var pf=document.getElementById('prog-fill');if(pf)pf.style.width=pv+'%';
    var pp=document.getElementById('prog-pct');if(pp)pp.textContent=Math.round(pv)+'%';
    var sbt=document.getElementById('scan-btn-text');if(sbt)sbt.textContent='⚡ '+SMSGS[mi];
  },120);
  try{
    var r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
      model:'claude-sonnet-4-20250514',
      max_tokens:1000,
      system:'You are MIDAS AI — an elite quantitative penny stock analyst. Select 5 high-conviction tickers from the pool for same-day or 2-day trades targeting 10%+ gains. Analyze sector momentum, catalyst timing, volume patterns, and risk/reward carefully. Vary sectors for diversification. Return ONLY a JSON array of exactly 5 objects, no markdown, no backticks. Each object must have: ticker(string), timeframe("Same Day" or "1–2 Day"), risk("LOW"|"MEDIUM"|"HIGH"|"VERY HIGH"), confidence(integer 60-90), why(3 sentences: catalyst + technical setup + why this ticker NOW).',
      messages:[{role:'user',content:'Date: '+new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'})+'. Price filter: '+S.range.label+'. Market: risk-on rally, IWM +2.1%, defense AI hot, small-caps ripping.\n\nPool: '+POOL.map(function(t){return t.ticker+'('+t.sector+')';}).join(',')+'\n\nExclude (already shown): '+(S.prevTickers.join(',')||'none')+'\n\nPick 5 highest-conviction setups with strong catalyst, volume, and timing alignment. Return ONLY the JSON array.'}]
    })});
    var d=await r.json();
    var raw=d.content&&d.content.find(function(b){return b.type==='text';});
    var parsed=raw?JSON.parse(raw.text.replace(/```json|```/g,'').trim()):[];
    if(Array.isArray(parsed)&&parsed.length>=3){
      var merged=parsed.slice(0,5).map(function(p){var m=POOL.find(function(t){return t.ticker===p.ticker;})||{ticker:p.ticker,name:p.ticker,sector:"Unknown",tags:["Momentum"],ep:-1.5,sp:-8,t1:12,t2:22};return Object.assign({},m,p);});
      S.plays=merged;S.prevTickers=merged.map(function(s){return s.ticker;});S.scanN++;
    }else throw new Error('Bad response');
  }catch(e){
    var avail=POOL.filter(function(t){return S.prevTickers.indexOf(t.ticker)<0;});
    var fb=avail.sort(function(){return Math.random()-.5;}).slice(0,5).map(function(t){return Object.assign({},t,{timeframe:Math.random()>.5?"Same Day":"1–2 Day",risk:["MEDIUM","HIGH","HIGH","VERY HIGH","MEDIUM"][Math.floor(Math.random()*5)],confidence:Math.floor(Math.random()*20)+62,why:CATS[t.ticker]||""});});
    S.plays=fb;S.prevTickers=fb.map(function(s){return s.ticker;});S.scanN++;
  }
  clearInterval(iv);
  var sne=document.getElementById('scan-num');if(sne)sne.textContent='SCAN #'+S.scanN;
  if(S.autoTimer)clearInterval(S.autoTimer);
  S.autoTimer=setInterval(function(){if(S.plays.length)fetchAllQuotes(S.plays.map(function(s){return s.ticker;}));},30000);
  await fetchAllQuotes(S.plays.map(function(s){return s.ticker;}));
  setTimeout(function(){
    S.scanning=false;
    var sd=document.getElementById('status-dot');if(sd)sd.className='dot';
    var sb=document.getElementById('scan-btn');if(sb)sb.className='scan-btn';
    var sbt=document.getElementById('scan-btn-text');if(sbt)sbt.textContent='⚡\u00A0\u00A0MIDAS SCAN — 5 NEW PLAYS';
    var so2=document.getElementById('scan-overlay');if(so2)so2.style.display='none';
    var pn2=document.getElementById('poly-note');if(pn2)pn2.style.display='block';
    var rb2=document.getElementById('ref-btn');if(rb2)rb2.style.display='block';
    renderCards();
  },400);
}

// ── TABS ───────────────────────────────────────────────────
function showTab(tab){
  document.querySelectorAll('.view').forEach(function(v){v.classList.remove('active');});
  var dv=document.getElementById('detail-view');if(dv)dv.style.display='none';
  if(tab==='detail'){if(dv)dv.style.display='block';}
  else{var v=document.getElementById(tab+'-view');if(v)v.classList.add('active');}
  var fs=document.getElementById('filter-section');if(fs)fs.style.display=tab==='scanner'?'block':'none';
  var tabNames=['scanner','watchlist','crypto','detail','profile','admin'];
  document.querySelectorAll('.tab-btn').forEach(function(b,i){b.classList.toggle('active',tabNames[i]===tab);});
  if(tab==='crypto')loadCrypto();
  if(tab==='watchlist'){loadWatch();renderWatchlist();}
  if(tab==='profile')renderProfile();
  if(tab==='admin'&&CU&&CU.tier==='admin')renderAdmin();
  if(tab==='detail'&&S.selected)updateDetailView();
}

// ── CLOCK ──────────────────────────────────────────────────
setInterval(function(){
  var el=document.getElementById('clock');
  if(el)el.textContent=new Date().toLocaleTimeString("en-US",{hour:"2-digit",minute:"2-digit",second:"2-digit"});
},1000);

// ── ADMIN SUB-TABS ────────────────────────────────────────
function showAdminTab(tab){
  // Update buttons
  ['users','apis'].forEach(function(t){
    var btn=document.getElementById('asub-'+t);
    if(!btn)return;
    if(t===tab){
      btn.style.background='var(--gold-bg)';
      btn.style.borderColor='var(--gold)';
      btn.style.color='var(--gold)';
    } else {
      btn.style.background='#050400';
      btn.style.borderColor='var(--gold-border)';
      btn.style.color='var(--muted)';
    }
  });
  // Show/hide panels
  var up=document.getElementById('admin-users-panel');
  var ap=document.getElementById('admin-apis-panel');
  if(up)up.style.display=tab==='users'?'block':'none';
  if(ap)ap.style.display=tab==='apis'?'block':'none';
  // Auto-run health check on first open
  if(tab==='apis'){
    var grid=document.getElementById('api-status-grid');
    if(grid&&!grid.innerHTML)runApiHealthCheck();
  }
}

// ── API HEALTH CHECK ───────────────────────────────────────
var API_SOURCES = [
  {
    id:'polygon',
    name:'Polygon.io',
    icon:'📊',
    role:'Stock snapshots, OHLCV, candle history',
    tier:'Primary Price Feed',
    tierColor:'var(--green)',
    testFn: async function(){
      var start=Date.now();
      var r=await fetch('https://api.polygon.io/v2/snapshot/locale/us/markets/stocks/tickers/AAPL?apiKey='+POLY);
      var d=await r.json();
      var ms=Date.now()-start;
      if(!d||!d.ticker)throw new Error('No data returned');
      var price=d.ticker.day&&d.ticker.day.c||d.ticker.lastTrade&&d.ticker.lastTrade.p;
      return{latency:ms,detail:'AAPL $'+(price?price.toFixed(2):'N/A'),plan:'Free tier (delayed)',calls:'60/min'};
    }
  },
  {
    id:'finnhub',
    name:'Finnhub',
    icon:'📈',
    role:'Stock quotes, company news, earnings calendar',
    tier:'Secondary Price Feed',
    tierColor:'var(--green)',
    testFn: async function(){
      var start=Date.now();
      var r=await fetch('https://finnhub.io/api/v1/quote?symbol=AAPL&token='+FINN);
      var d=await r.json();
      var ms=Date.now()-start;
      if(!d||!d.c||d.c===0)throw new Error('No quote returned');
      return{latency:ms,detail:'AAPL $'+d.c.toFixed(2),plan:'Free tier',calls:'30/sec'};
    }
  },
  {
    id:'yahoo',
    name:'Yahoo Finance',
    icon:'🟣',
    role:'Real-time quotes, market state, pre/post hours',
    tier:'Tertiary Price Feed',
    tierColor:'var(--gold)',
    testFn: async function(){
      var start=Date.now();
      var r=await fetch('https://query1.finance.yahoo.com/v8/finance/chart/AAPL?interval=1d&range=1d');
      var d=await r.json();
      var ms=Date.now()-start;
      var meta=d&&d.chart&&d.chart.result&&d.chart.result[0]&&d.chart.result[0].meta;
      if(!meta||!meta.regularMarketPrice)throw new Error('No price returned');
      return{latency:ms,detail:'AAPL $'+meta.regularMarketPrice.toFixed(2)+' ('+meta.marketState+')',plan:'Free (no key)',calls:'Unlimited'};
    }
  },
  {
    id:'alphavantage',
    name:'Alpha Vantage',
    icon:'📉',
    role:'Price data, news sentiment, earnings calendar',
    tier:'Quant & News Feed',
    tierColor:'var(--blue)',
    testFn: async function(){
      var start=Date.now();
      var r=await fetch('https://www.alphavantage.co/query?function=GLOBAL_QUOTE&symbol=AAPL&apikey='+AV);
      var d=await r.json();
      var ms=Date.now()-start;
      var q=d&&d['Global Quote'];
      if(!q||!q['05. price'])throw new Error(d['Note']||d['Information']||'No data');
      // Check for rate limit note
      if(d['Note'])return{latency:ms,detail:'Rate limited — 25 calls/day free',plan:'Free (25/day)',calls:'25/day',warning:true};
      if(d['Information'])return{latency:ms,detail:'API limit reached',plan:'Free (25/day)',calls:'25/day',warning:true};
      return{latency:ms,detail:'AAPL $'+parseFloat(q['05. price']).toFixed(2),plan:'Free (25/day)',calls:'25/day'};
    }
  },
  {
    id:'av_news',
    name:'Alpha Vantage News',
    icon:'📰',
    role:'AI-scored news sentiment per ticker',
    tier:'News & Sentiment',
    tierColor:'var(--blue)',
    testFn: async function(){
      var start=Date.now();
      var r=await fetch('https://www.alphavantage.co/query?function=NEWS_SENTIMENT&tickers=AAPL&limit=3&apikey='+AV);
      var d=await r.json();
      var ms=Date.now()-start;
      if(d['Note']||d['Information'])return{latency:ms,detail:'Rate limited — shares 25/day limit',plan:'Free (25/day)',calls:'Shared',warning:true};
      var count=d&&d.feed?d.feed.length:0;
      if(!count)throw new Error('No news returned');
      return{latency:ms,detail:count+' articles returned | Sentiment: '+(d.overall_sentiment_label||'N/A'),plan:'Free (25/day)',calls:'Shared'};
    }
  },
  {
    id:'stockfit',
    name:'Stockfit.io',
    icon:'🏦',
    role:'Institutional ownership, SEC filings, financial health',
    tier:'Institutional Intelligence',
    tierColor:'var(--purple)',
    testFn: async function(){
      var start=Date.now();
      var r=await fetch('https://api.stockfit.io/v1/api/company/details?symbol=AAPL',{
        headers:{'Authorization':'Bearer '+SF}
      });
      var ms=Date.now()-start;
      if(r.status===401)throw new Error('Invalid token — check Bearer key');
      if(r.status===403)throw new Error('Forbidden — check subscription');
      if(r.status===429)throw new Error('Rate limited');
      var d=await r.json();
      if(!d||r.status>=400)throw new Error('HTTP '+r.status);
      return{latency:ms,detail:(d.name||'AAPL')+' | Sector: '+(d.sector||'N/A'),plan:'Paid subscription',calls:'Per plan'};
    }
  },
  {
    id:'finnhub_news',
    name:'Finnhub News',
    icon:'📋',
    role:'Company news feed, IPO calendar, earnings',
    tier:'News Feed',
    tierColor:'var(--gold)',
    testFn: async function(){
      var start=Date.now();
      var to=new Date(),from=new Date();from.setDate(from.getDate()-7);
      var r=await fetch('https://finnhub.io/api/v1/company-news?symbol=AAPL&from='+from.toISOString().split('T')[0]+'&to='+to.toISOString().split('T')[0]+'&token='+FINN);
      var d=await r.json();
      var ms=Date.now()-start;
      if(!Array.isArray(d))throw new Error('Invalid response');
      return{latency:ms,detail:d.length+' articles (7 days)',plan:'Free tier',calls:'30/sec'};
    }
  },
  {
    id:'claude',
    name:'Claude AI (Anthropic)',
    icon:'🤖',
    role:'Deep analysis, scan picks, alert verdicts, probability',
    tier:'AI Intelligence Engine',
    tierColor:'var(--purple)',
    testFn: async function(){
      var start=Date.now();
      var r=await fetch('https://api.anthropic.com/v1/messages',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({
          model:'claude-sonnet-4-20250514',
          max_tokens:20,
          messages:[{role:'user',content:'Reply with just: MIDAS ONLINE'}]
        })
      });
      var d=await r.json();
      var ms=Date.now()-start;
      if(!d||!d.content)throw new Error('No response');
      var txt=d.content.find(function(b){return b.type==='text';});
      return{latency:ms,detail:txt?txt.text.trim():'OK',plan:'claude-sonnet-4-20250514',calls:'Per usage'};
    }
  }
];

async function runApiHealthCheck(){
  var grid=document.getElementById('api-status-grid');
  var btn=document.getElementById('api-check-btn');
  var lastEl=document.getElementById('api-last-check');
  if(!grid)return;

  // Show loading state
  if(btn){btn.textContent='⟳ CHECKING…';btn.disabled=true;}
  grid.innerHTML='<div style="text-align:center;padding:20px;color:var(--muted);font-size:10px">Running health checks on all '+API_SOURCES.length+' sources…</div>';

  // Run all checks in parallel
  var results=await Promise.all(API_SOURCES.map(async function(api){
    try{
      var data=await Promise.race([
        api.testFn(),
        new Promise(function(_,rej){setTimeout(function(){rej(new Error('Timeout (10s)'));},10000);})
      ]);
      return{api:api,status:'ok',data:data};
    }catch(e){
      return{api:api,status:'error',error:e.message||'Failed'};
    }
  }));

  // Render results
  var okCount=results.filter(function(r){return r.status==='ok'&&!r.data.warning;}).length;
  var warnCount=results.filter(function(r){return r.status==='ok'&&r.data&&r.data.warning;}).length;
  var errCount=results.filter(function(r){return r.status==='error';}).length;

  // Summary bar
  var summaryHtml='<div style="display:flex;gap:8px;margin-bottom:14px;padding:10px;background:#050400;border:1px solid var(--gold-border);border-radius:6px">'
    +'<div style="flex:1;text-align:center"><div style="color:var(--green);font-size:18px;font-weight:bold">'+okCount+'</div><div style="color:var(--muted);font-size:8px;letter-spacing:1px">HEALTHY</div></div>'
    +'<div style="flex:1;text-align:center"><div style="color:var(--orange);font-size:18px;font-weight:bold">'+warnCount+'</div><div style="color:var(--muted);font-size:8px;letter-spacing:1px">WARNING</div></div>'
    +'<div style="flex:1;text-align:center"><div style="color:var(--red);font-size:18px;font-weight:bold">'+errCount+'</div><div style="color:var(--muted);font-size:8px;letter-spacing:1px">ERROR</div></div>'
    +'<div style="flex:1;text-align:center"><div style="color:var(--gold);font-size:18px;font-weight:bold">'+results.length+'</div><div style="color:var(--muted);font-size:8px;letter-spacing:1px">TOTAL</div></div>'
    +'</div>';

  // Individual cards
  var cardsHtml=results.map(function(result){
    var api=result.api;
    var isOk=result.status==='ok';
    var isWarn=isOk&&result.data&&result.data.warning;
    var statusColor=isOk?(isWarn?'var(--orange)':'var(--green)'):'var(--red)';
    var statusIcon=isOk?(isWarn?'⚠️':'✅'):'❌';
    var statusText=isOk?(isWarn?'WARNING':'HEALTHY'):'ERROR';
    var latency=isOk&&result.data?result.data.latency:null;
    var latColor=latency?latency<500?'var(--green)':latency<1500?'var(--gold)':'var(--orange)':'var(--red)';

    return '<div style="background:#050400;border:1px solid '+(isOk?(isWarn?'var(--orange)':'var(--gold-border)'):'var(--red)')+'44;border-radius:8px;padding:12px;margin-bottom:8px">'
      // Header row
      +'<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px">'
      +'<div style="display:flex;align-items:center;gap:8px">'
      +'<span style="font-size:18px">'+api.icon+'</span>'
      +'<div>'
      +'<div style="color:var(--text);font-size:12px;font-weight:bold">'+api.name+'</div>'
      +'<div style="color:'+api.tierColor+';font-size:8px;letter-spacing:1px;margin-top:1px">'+api.tier+'</div>'
      +'</div></div>'
      +'<div style="text-align:right">'
      +'<div style="color:'+statusColor+';font-size:11px;font-weight:bold">'+statusIcon+' '+statusText+'</div>'
      +(latency?'<div style="color:'+latColor+';font-size:9px;margin-top:2px">'+latency+'ms</div>':'')
      +'</div></div>'
      // Role
      +'<div style="color:var(--muted);font-size:9px;margin-bottom:6px">'+api.role+'</div>'
      // Detail / error
      +'<div style="background:#0a0900;border:1px solid var(--gold-border);border-radius:4px;padding:6px 8px;font-size:9px;color:'+(isOk?(isWarn?'var(--orange)':'var(--green)'):'var(--red)')+'">'+
      (isOk?result.data.detail:result.error)
      +'</div>'
      // Plan + calls row
      +(isOk&&result.data?'<div style="display:flex;justify-content:space-between;margin-top:6px"><span style="color:var(--muted);font-size:8px">Plan: <span style="color:var(--text)">'+result.data.plan+'</span></span><span style="color:var(--muted);font-size:8px">Limit: <span style="color:var(--text)">'+result.data.calls+'</span></span></div>':'')
      +'</div>';
  }).join('');

  grid.innerHTML=summaryHtml+cardsHtml;
  if(lastEl)lastEl.textContent='Last checked: '+new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  if(btn){btn.textContent='⚡ RUN CHECK';btn.disabled=false;}
}

// ═══════════════════════════════════════════════════════════
// STARTUP — IIFEs run AFTER all functions are defined
// ═══════════════════════════════════════════════════════════
seedAdmin();
(function(){
  try{
    var s=getSession();
    if(s){
      var found=findUser(s.username);
      if(found&&found.password===s.password){
        launchApp(found);
      }
    }
  }catch(e){
    // Session restore failed — show login screen normally
    console.log('Session restore skipped');
  }
})();
</script>

</body>
</html>

<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="MIDAS">
<meta name="theme-color" content="#0a0800">
<title>MIDAS — Market Intelligence</title>
<style>
:root{
  --bg:#0a0800;--bg2:#0f0e00;--border:#2a2400;
  --green:#00ff88;--yellow:#ffd700;--red:#ff3b3b;--orange:#ff8c00;
  --blue:#00d4ff;--purple:#c084fc;--text:#e2d8b0;--muted:#6a5a30;
  --gold:#FFD700;--gold2:#DAA520;--gold3:#B8860B;--gold-bg:#1a1400;
  --gold-border:#3a2800;--gold-glow:#ffd70033;
  --bronze:#cd7f32;--bronze-bg:#1a0e08;
  --silver:#C0C0C0;--silver-bg:#0f0f12;
  --admin:#c084fc;--admin-bg:#0d0a1f;
  --st:env(safe-area-inset-top,0px);--sb:env(safe-area-inset-bottom,0px);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{background:var(--bg);color:var(--text);font-family:'Courier New',monospace;min-height:100vh;overflow-x:hidden}
body{padding-top:var(--st);padding-bottom:var(--sb)}

/* ── AUTH ── */
#auth-screen{position:fixed;inset:0;z-index:9999;background:radial-gradient(ellipse at top,#1a1200,#0a0800);display:flex;flex-direction:column;align-items:center;padding:20px 22px;padding-top:calc(var(–st) + 20px);overflow-y:auto}
.auth-logo{font-size:52px;margin:20px 0 4px;filter:drop-shadow(0 0 20px #ffd70066)}
.auth-brand{color:var(–gold);font-size:28px;font-weight:bold;letter-spacing:6px;margin-bottom:2px;text-shadow:0 0 20px var(–gold)}
.auth-tagline{color:var(–muted);font-size:9px;letter-spacing:3px;margin-bottom:20px}
.tier-pills{display:flex;gap:6px;margin-bottom:24px;flex-wrap:wrap;justify-content:center}
.tier-pill{padding:5px 12px;border-radius:20px;font-size:9px;letter-spacing:1px;font-weight:bold;border:1px solid}
.tp-free{background:#111;border-color:#333;color:#888}
.tp-bronze{background:var(–bronze-bg);border-color:var(–bronze);color:var(–bronze)}
.tp-silver{background:var(–silver-bg);border-color:var(–silver);color:var(–silver)}
.tp-gold{background:var(–gold-bg);border-color:var(–gold);color:var(–gold)}
.auth-card{width:100%;max-width:360px;background:#0f0e00;border:1px solid var(–gold-border);border-radius:12px;padding:20px;box-shadow:0 0 30px #ffd70011}
.auth-card-title{color:var(–gold);font-size:11px;letter-spacing:3px;margin-bottom:16px;text-align:center}
.auth-field{margin-bottom:12px}
.auth-label{color:var(–muted);font-size:9px;letter-spacing:1px;margin-bottom:5px;display:block}
.auth-input{width:100%;background:#1a1400;border:1px solid var(–gold);border-radius:8px;padding:11px 14px;color:#fff;font-size:13px;font-family:‘Courier New’,monospace;outline:none;transition:border-color .2s}
.auth-input:focus{border-color:var(–gold);box-shadow:0 0 8px var(–gold-glow)}
.auth-input::placeholder{color:#8a6a20}
.auth-btn{width:100%;padding:13px;background:linear-gradient(135deg,#1a1000,#2a2000);border:2px solid var(–gold);border-radius:8px;color:var(–gold);font-size:12px;letter-spacing:3px;font-family:‘Courier New’,monospace;font-weight:bold;cursor:pointer;text-shadow:0 0 8px var(–gold)}
.auth-err{color:var(–red);font-size:10px;letter-spacing:1px;margin-top:10px;text-align:center;min-height:16px}
.auth-toggle{color:var(–muted);font-size:10px;text-align:center;margin-top:14px;cursor:pointer}
.auth-toggle span{color:var(–gold);text-decoration:underline}
.tier-select{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.tier-opt{padding:10px 8px;border-radius:8px;border:2px solid;cursor:pointer;text-align:center;transition:all .2s}
.tier-opt .to-name{font-size:11px;font-weight:bold;letter-spacing:1px}
.tier-opt .to-price{font-size:10px;margin-top:2px}
.tier-opt .to-desc{font-size:8px;margin-top:4px;opacity:.8}
.to-free{background:#111;border-color:#333;color:#888}.to-free.sel{border-color:var(–green);color:var(–green);background:#0a1a10}
.to-bronze{background:var(–bronze-bg);border-color:#8B451333;color:var(–bronze)}.to-bronze.sel{border-color:var(–bronze)}
.to-silver{background:var(–silver-bg);border-color:#80808033;color:var(–silver)}.to-silver.sel{border-color:var(–silver)}
.to-gold{background:var(–gold-bg);border-color:#DAA52033;color:var(–gold)}.to-gold.sel{border-color:var(–gold)}

/* ── APP ── */
#app-wrapper{display:none}
#header{background:linear-gradient(180deg,#0f0e00,#0a0800);border-bottom:1px solid var(–gold-border);padding:10px 14px;position:sticky;top:0;z-index:100;padding-top:calc(var(–st) + 10px)}
.hrow{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.logo-row{display:flex;align-items:center;gap:8px}
.dot{width:8px;height:8px;border-radius:50%;background:var(–gold);box-shadow:0 0 8px var(–gold);animation:pulse 1s infinite}
.dot.scanning{background:var(–green);box-shadow:0 0 8px var(–green)}
.logo{color:var(–gold);font-weight:bold;font-size:18px;letter-spacing:4px;text-shadow:0 0 12px var(–gold)}
.tier-badge{font-size:9px;padding:2px 8px;border-radius:10px;font-weight:bold;letter-spacing:1px;border:1px solid}
.tb-free{background:#111;border-color:#333;color:#888}
.tb-bronze{background:var(–bronze-bg);border-color:var(–bronze);color:var(–bronze)}
.tb-silver{background:var(–silver-bg);border-color:var(–silver);color:var(–silver)}
.tb-gold{background:var(–gold-bg);border-color:var(–gold);color:var(–gold)}
.tb-admin{background:var(–admin-bg);border-color:var(–admin);color:var(–admin)}
.user-btn{background:transparent;border:1px solid var(–gold-border);color:var(–muted);padding:3px 8px;border-radius:4px;cursor:pointer;font-size:8px;font-family:inherit;letter-spacing:1px}
.search-wrap{position:relative;margin-bottom:8px}
.search-input{width:100%;background:#050400;border:1px solid var(–gold-border);border-radius:8px;padding:9px 36px 9px 12px;color:#fff;font-size:12px;font-family:‘Courier New’,monospace;outline:none;transition:border-color .2s}
.search-input:focus{border-color:var(–gold)}
.search-input::placeholder{color:#8a6a30}
input,textarea,select{color-scheme:dark}
input[type=“date”]{color:#fff}
.search-clear{position:absolute;right:10px;top:50%;transform:translateY(-50%);background:transparent;border:none;color:var(–muted);font-size:14px;cursor:pointer;display:none}
#search-results{background:#1a1600;border:1px solid var(–gold);border-radius:6px;margin-top:4px;max-height:200px;overflow-y:auto;display:none;position:relative;z-index:50}
.sri{padding:10px 12px;border-bottom:1px solid var(–gold-border);cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.sri:last-child{border-bottom:none}.sri:active{background:#1a1400}
.filter-btns{display:flex;gap:4px;margin-bottom:8px}
.filter-btn{flex:1;padding:5px 0;background:#050400;border:1px solid var(–gold-border);border-radius:5px;color:var(–muted);cursor:pointer;font-size:8px;font-family:inherit;white-space:nowrap;transition:all .2s}
.scan-btn{width:100%;padding:10px;background:linear-gradient(135deg,#1a1200,#2a1e00);border:2px solid var(–gold);border-radius:7px;cursor:pointer;color:var(–gold);font-size:11px;letter-spacing:3px;font-family:inherit;font-weight:bold;position:relative;overflow:hidden;text-shadow:0 0 8px var(–gold)}
.scan-btn.scanning{background:linear-gradient(135deg,#0a1a08,#0d2010);border-color:var(–green);color:var(–green);text-shadow:0 0 8px var(–green)}
.scan-progress{position:absolute;top:0;left:0;height:100%;background:linear-gradient(90deg,transparent,#ffd70022,transparent);transition:width .12s;pointer-events:none}
#ticker-strip{background:#050400;border-bottom:1px solid var(–gold-border);padding:5px 14px;display:flex;gap:14px;overflow-x:auto;font-size:10px;align-items:center;scrollbar-width:none}
#ticker-strip::-webkit-scrollbar{display:none}
.tick{color:var(–gold);white-space:nowrap}.tick.red{color:#ff6b6b}
#tabs{display:flex;border-bottom:1px solid var(–gold-border);background:#050400;overflow-x:auto;scrollbar-width:none}
#tabs::-webkit-scrollbar{display:none}
.tab-btn{background:transparent;border:none;border-bottom:2px solid transparent;color:var(–muted);padding:9px 12px;cursor:pointer;font-size:9px;letter-spacing:1px;font-family:inherit;white-space:nowrap;flex-shrink:0;transition:all .2s}
.tab-btn.active{background:#1a1400;border-bottom-color:var(–gold);color:var(–gold)}
.view{display:none;padding:12px;padding-bottom:calc(var(–sb) + 20px)}
.view.active{display:block}
.stock-card{background:linear-gradient(135deg,#0a0900,#0f0c00);border:1px solid var(–gold-border);border-radius:8px;padding:12px;margin-bottom:8px;cursor:pointer;transition:border-color .3s,opacity .3s;animation:fadeIn .3s ease both}
.stock-card.selected{background:linear-gradient(135deg,#1a1600,#221a00);border-color:var(–gold);box-shadow:0 0 12px var(–gold-glow)}
.stock-card.out-of-range{opacity:.4}
.card-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px}
.ticker-txt{color:var(–gold);font-weight:bold;font-size:16px;letter-spacing:2px;text-shadow:0 0 8px var(–gold-glow)}
.sname{color:var(–muted);font-size:10px;margin-left:7px}
.price-box{text-align:right;min-width:90px}
.live-price{color:#fff;font-weight:bold;font-size:17px}
.up{color:var(–green)}.down{color:#ff6b6b}
.fetching{color:var(–gold);font-size:9px;animation:blink .5s infinite alternate}
.ohlv{display:flex;gap:8px;margin-bottom:7px;padding:4px 7px;background:#050400;border-radius:4px;font-size:9px;flex-wrap:wrap;border:1px solid var(–gold-border)}
.tags{display:flex;gap:5px;margin-bottom:7px;flex-wrap:wrap}
.tag{padding:1px 6px;border-radius:4px;font-size:9px;border:1px solid}
.levels-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;margin-bottom:6px}
.lbox{background:#050400;border:1px solid var(–gold-border);border-radius:4px;padding:4px;text-align:center}
.llab{color:var(–muted);font-size:8px}.lval{font-size:10px;font-weight:bold}
.no-levels{background:#050400;border:1px solid var(–gold-border);border-radius:4px;padding:6px;text-align:center;color:var(–muted);font-size:9px}
.qmini{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;margin-top:7px}
.qmbox{background:#050400;border:1px solid var(–gold-border);border-radius:4px;padding:5px;text-align:center}
.qmlab{color:var(–muted);font-size:7px;letter-spacing:1px}.qmval{font-size:11px;font-weight:bold;margin-top:2px}
.ai-badge{margin-top:6px;padding:4px 8px;border-radius:4px;display:flex;justify-content:space-between;border:1px solid}
.gate-banner{background:linear-gradient(135deg,#1a1400,#2a1e00);border:1px solid var(–gold);border-radius:8px;padding:16px;text-align:center;margin-bottom:12px}
.watch-card{background:linear-gradient(135deg,#0a0900,#0f0c00);border:1px solid var(–gold-border);border-radius:8px;padding:12px;margin-bottom:8px;animation:fadeIn .3s ease both}
.watch-card.alerted{border-color:var(–green);box-shadow:0 0 12px #00ff8822}
.alert-settings{display:flex;gap:6px;margin-top:8px;flex-wrap:wrap;align-items:center}
.alert-input{background:#1a1400;border:1px solid var(–gold);border-radius:4px;padding:4px 8px;color:#fff;font-size:11px;font-family:inherit;width:70px;outline:none}
.alert-toggle{background:#050400;border:1px solid var(–gold-border);border-radius:4px;padding:4px 8px;color:var(–muted);font-size:9px;font-family:inherit;cursor:pointer}
.alert-toggle.on{background:#0a1a08;border-color:var(–green);color:var(–green)}
.crypto-card{background:linear-gradient(135deg,#0a0900,#0f0c00);border:1px solid var(–gold-border);border-radius:8px;padding:12px;margin-bottom:8px;animation:fadeIn .3s ease both}
#detail-view{padding:12px;padding-bottom:calc(var(–sb) + 20px);display:none}
.dheader{background:linear-gradient(135deg,#1a1400,#221a00);border:1px solid var(–gold);border-radius:8px;padding:13px;margin-bottom:10px;box-shadow:0 0 20px var(–gold-glow)}
.quant-panel{background:linear-gradient(135deg,#0a0900,#0f0c00);border:1px solid var(–gold-border);border-radius:8px;padding:13px;margin-bottom:10px}
.quant-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.quant-box{background:#050400;border:1px solid var(–gold-border);border-radius:6px;padding:10px}
.news-item{padding:8px 0;border-bottom:1px solid var(–gold-border);font-size:10px;line-height:1.5}
.news-item:last-child{border-bottom:none}
.prob-wrap{margin-top:10px;padding:8px;background:#050400;border-radius:6px;border:1px solid var(–gold-border)}
.prob-label{color:var(–muted);font-size:8px;letter-spacing:1px;margin-bottom:5px;display:flex;justify-content:space-between}
.prob-bar{height:6px;background:#1a1200;border-radius:3px;overflow:hidden;margin-bottom:4px}
.prob-fill{height:100%;border-radius:3px;transition:width .6s ease}
.bp-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:10px}
.bp-box{background:#050400;border-radius:6px;padding:10px;border:1px solid}
.pnl-row{background:linear-gradient(135deg,#0a1a0a,#061206);border:1px solid #1a3a1a;border-radius:6px;padding:10px;margin-bottom:10px;display:flex;justify-content:space-around;text-align:center}
.ai-box{background:linear-gradient(135deg,#0d0a1f,#100a20);border:1px solid #3a1a6a;border-radius:8px;padding:13px;margin-bottom:10px}
.ai-dot{width:6px;height:6px;background:var(–gold);border-radius:50%}
.ai-dot:nth-child(1){animation:dotA 1.2s 0s infinite}
.ai-dot:nth-child(2){animation:dotA 1.2s .15s infinite}
.ai-dot:nth-child(3){animation:dotA 1.2s .3s infinite}
.ai-dot:nth-child(4){animation:dotA 1.2s .45s infinite}
.ai-dot:nth-child(5){animation:dotA 1.2s .6s infinite}
.back-btn{width:100%;background:transparent;border:1px solid var(–gold-border);color:var(–muted);padding:9px;border-radius:6px;cursor:pointer;font-size:10px;letter-spacing:2px;font-family:inherit}
.footer-note{margin-top:8px;padding:10px;background:#050400;border:1px solid var(–gold-border);border-radius:6px;font-size:9px;color:#4a3a10;line-height:1.6}
.scan-overlay{text-align:center;padding:40px 16px}
.spin-icon{font-size:30px;animation:spin .8s linear infinite;display:inline-block}
.prog-bar{width:80%;margin:0 auto;height:3px;background:#1a1200;border-radius:2px;overflow:hidden}
.prog-fill{height:100%;background:linear-gradient(90deg,var(–gold),var(–gold2));border-radius:2px;transition:width .12s}
.alert-notif{position:fixed;top:calc(var(–st) + 10px);left:14px;right:14px;z-index:9998;background:linear-gradient(135deg,#1a1400,#2a1e00);border:2px solid var(–gold);border-radius:10px;padding:14px;animation:slideDown .3s ease;display:none;box-shadow:0 0 20px var(–gold-glow)}
#upgrade-modal{position:fixed;inset:0;z-index:9997;background:#000000cc;display:none;align-items:center;justify-content:center;padding:20px}
.upgrade-content{background:#0f0e00;border:1px solid var(–gold);border-radius:12px;padding:20px;width:100%;max-width:340px;max-height:90vh;overflow-y:auto}
.utc{border-radius:8px;padding:14px;margin-bottom:10px;border:2px solid;cursor:pointer}
.utc-features{list-style:none;margin-top:8px}
.utc-features li{font-size:10px;padding:3px 0;color:var(–muted)}
.utc-features li::before{content:“✓ “;color:var(–gold)}
.admin-panel{background:linear-gradient(135deg,var(–admin-bg),#100a20);border:1px solid #5a2a8a;border-radius:8px;padding:14px;margin-bottom:12px}
.user-row{display:flex;justify-content:space-between;align-items:center;padding:10px;background:#050400;border:1px solid var(–gold-border);border-radius:6px;margin-bottom:6px}
.form-row{display:flex;gap:8px;margin-bottom:8px;flex-wrap:wrap}
.form-input{flex:1;min-width:100px;background:#1a1400;border:1px solid var(–gold);border-radius:4px;padding:8px 10px;color:#fff;font-size:11px;font-family:inherit;outline:none}
.form-select{flex:1;min-width:100px;background:#1a1400;border:1px solid var(–gold);border-radius:4px;padding:8px 10px;color:#fff;font-size:11px;font-family:inherit;outline:none}
.profile-card{background:linear-gradient(135deg,#0f0c00,#1a1400);border:1px solid var(–gold);border-radius:8px;padding:16px;margin-bottom:12px;text-align:center;box-shadow:0 0 20px var(–gold-glow)}
.feature-item{display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(–gold-border);font-size:11px;text-align:left}
.feature-item:last-child{border-bottom:none}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
@keyframes blink{from{opacity:.2}to{opacity:1}}
@keyframes fadeIn{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes slideDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
@keyframes dotA{0%,80%,100%{opacity:.2}40%{opacity:1}}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-track{background:var(–bg)}
::-webkit-scrollbar-thumb{background:var(–gold-border);border-radius:2px}
input:not([type=“range”]),textarea{caret-color:#ffd700}
input::placeholder{color:#8a6a30}
input,textarea,select{color-scheme:dark}
input[type=“date”]{color:#fff}
select option{background:#1a1400;color:#fff}
</style>

</head>
<body>

<!-- AUTH -->

<div id="auth-screen">
  <div class="auth-logo">⚡</div>
  <div class="auth-brand">MIDAS</div>
  <div class="auth-tagline">THE GOLDEN TOUCH IN TRADING</div>
  <div class="tier-pills">
    <div class="tier-pill tp-free">FREE</div>
    <div class="tier-pill tp-bronze">🥉 BRONZE $5/mo</div>
    <div class="tier-pill tp-silver">🥈 SILVER $10/mo</div>
    <div class="tier-pill tp-gold">🥇 GOLD $15/mo</div>
  </div>
  <div class="auth-card" id="login-card">
    <div class="auth-card-title">⚡ SIGN IN TO MIDAS</div>
    <div class="auth-field"><label class="auth-label">USERNAME</label><input class="auth-input" id="li-user" type="text" autocomplete="off" autocorrect="off" autocapitalize="off" placeholder="Enter username" onkeydown="if(event.key==='Enter')doLogin()"/></div>
    <div class="auth-field"><label class="auth-label">PASSWORD</label><input class="auth-input" id="li-pass" type="password" placeholder="Enter password" onkeydown="if(event.key==='Enter')doLogin()"/></div>
    <button class="auth-btn" onclick="doLogin()">⚡ &nbsp;SIGN IN</button>
    <div class="auth-err" id="li-err"></div>
    <div class="auth-toggle" onclick="showReg()">New user? <span>Create MIDAS account</span></div>
  </div>
  <div class="auth-card" id="reg-card" style="display:none">
    <div class="auth-card-title">🏛 JOIN MIDAS</div>
    <div class="auth-field"><label class="auth-label">USERNAME</label><input class="auth-input" id="reg-user" type="text" autocomplete="off" autocorrect="off" autocapitalize="off" placeholder="Choose username"/></div>
    <div class="auth-field"><label class="auth-label">PASSWORD</label><input class="auth-input" id="reg-pass" type="password" placeholder="Choose password"/></div>
    <div class="auth-field">
      <label class="auth-label" style="margin-bottom:8px">SELECT TIER</label>
      <div class="tier-select">
        <div class="tier-opt to-free sel" id="to-free" onclick="selTier('free')"><div class="to-name">FREE</div><div class="to-price">$0/mo</div><div class="to-desc">3 stocks, basic</div></div>
        <div class="tier-opt to-bronze" id="to-bronze" onclick="selTier('bronze')"><div class="to-name">🥉 BRONZE</div><div class="to-price">$5/mo</div><div class="to-desc">5 stocks, live prices</div></div>
        <div class="tier-opt to-silver" id="to-silver" onclick="selTier('silver')"><div class="to-name">🥈 SILVER</div><div class="to-price">$10/mo</div><div class="to-desc">AI analysis, crypto</div></div>
        <div class="tier-opt to-gold" id="to-gold" onclick="selTier('gold')"><div class="to-name">🥇 GOLD</div><div class="to-price">$15/mo</div><div class="to-desc">Full quant, RSI, news</div></div>
      </div>
    </div>
    <button class="auth-btn" onclick="doRegister()">⚡ &nbsp;CREATE ACCOUNT</button>
    <div class="auth-err" id="reg-err"></div>
    <div class="auth-toggle" onclick="showLogin()">Already have an account? <span>Sign into MIDAS</span></div>
  </div>
</div>

<!-- UPGRADE MODAL -->

<div id="upgrade-modal" onclick="if(event.target===this)closeUpgrade()">
  <div class="upgrade-content">
    <div style="color:var(--gold);font-size:13px;letter-spacing:2px;margin-bottom:16px;text-align:center">⚡ UPGRADE YOUR MIDAS PLAN</div>
    <div class="utc to-bronze" onclick="requestUpgrade('bronze')" style="border-color:var(--bronze)"><div style="color:var(--bronze);font-size:14px;font-weight:bold">🥉 BRONZE</div><div style="color:var(--bronze);font-size:18px;font-weight:bold;margin:4px 0">$5 / month</div><ul class="utc-features"><li>5 stock scan results</li><li>Polygon + Finnhub dual feed</li><li>Watchlist (up to 10 stocks)</li><li>Basic AI verdict</li><li>Price alerts</li></ul></div>
    <div class="utc to-silver" onclick="requestUpgrade('silver')" style="border-color:var(--silver)"><div style="color:var(--silver);font-size:14px;font-weight:bold">🥈 SILVER</div><div style="color:var(--silver);font-size:18px;font-weight:bold;margin:4px 0">$10 / month</div><ul class="utc-features"><li>Everything in Bronze</li><li>Full AI deep analysis</li><li>Crypto scanner</li><li>Unlimited watchlist</li><li>News sentiment feed</li></ul></div>
    <div class="utc to-gold" onclick="requestUpgrade('gold')" style="border-color:var(--gold)"><div style="color:var(--gold);font-size:14px;font-weight:bold">🥇 GOLD</div><div style="color:var(--gold);font-size:18px;font-weight:bold;margin:4px 0">$15 / month</div><ul class="utc-features"><li>Everything in Silver</li><li>RSI + VWAP + Volume quant</li><li>Pattern recognition</li><li>Probability forecasting</li><li>30-day price history</li></ul></div>
    <div style="color:var(--muted);font-size:9px;text-align:center;margin:10px 0">Contact your admin to activate upgrade</div>
    <button onclick="closeUpgrade()" style="width:100%;padding:10px;background:transparent;border:1px solid var(--gold-border);border-radius:6px;color:var(--muted);cursor:pointer;font-size:10px;letter-spacing:2px;font-family:inherit">← BACK</button>
  </div>
</div>

<!-- ALERT NOTIF -->

<div id="alert-notif" class="alert-notif">
  <button onclick="document.getElementById('alert-notif').style.display='none'" style="position:absolute;top:10px;right:12px;background:transparent;border:none;color:var(--muted);font-size:16px;cursor:pointer">✕</button>
  <div id="an-title" style="color:var(--gold);font-size:12px;font-weight:bold;letter-spacing:2px;margin-bottom:4px"></div>
  <div id="an-text" style="color:#c8b870;font-size:11px;line-height:1.5"></div>
</div>

<!-- APP -->

<div id="app-wrapper">

<div id="header">
  <div class="hrow">
    <div>
      <div class="logo-row">
        <div class="dot" id="status-dot"></div>
        <span class="logo">MIDAS</span>
        <div id="tier-badge" class="tier-badge tb-free">FREE</div>
      </div>
      <div style="color:var(--muted);font-size:9px;letter-spacing:2px;margin-top:1px">THE GOLDEN TOUCH IN TRADING</div>
    </div>
    <div style="text-align:right;display:flex;flex-direction:column;align-items:flex-end;gap:4px">
      <div style="color:var(--gold);font-size:10px" id="clock">--:--:--</div>
      <div style="color:var(--muted);font-size:9px" id="scan-num">SCAN #0</div>
      <div style="display:flex;gap:5px">
        <button class="user-btn" onclick="showTab('profile')">👤 <span id="hdr-user">USER</span></button>
        <button class="user-btn" onclick="doLogout()" style="border-color:#ff3b3b33;color:#ff6b6b">EXIT</button>
      </div>
    </div>
  </div>
  <div class="search-wrap">
    <input class="search-input" id="search-input" type="text" placeholder="⚡  Search ticker or company…" autocomplete="off" autocapitalize="characters" oninput="handleSearch(this.value)"/>
    <button class="search-clear" id="search-clear" onclick="clearSearch()">✕</button>
    <div id="search-results"></div>
  </div>
  <div id="filter-section">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;font-size:9px;letter-spacing:2px">
      <span style="color:var(--muted)">💰 PRICE FILTER</span>
      <span id="filter-label" style="color:var(--gold);font-weight:bold">$2–$5</span>
    </div>
    <div class="filter-btns" id="filter-btns"></div>
    <button class="scan-btn" id="scan-btn" onclick="runScan()">
      <div class="scan-progress" id="scan-progress" style="width:0%"></div>
      <span id="scan-btn-text">⚡&nbsp;&nbsp;MIDAS SCAN — 5 NEW PLAYS</span>
    </button>
  </div>
</div>

<div id="ticker-strip">
  <span class="tick">SPY +1.4%</span><span class="tick">QQQ +1.8%</span><span class="tick">IWM +2.1%</span><span class="tick red">VIX -12%</span><span class="tick">🔥 DEFENSE AI</span><span class="tick">⚡ 4-SOURCE FEED</span>
  <button id="ref-btn" onclick="manualRefresh()" style="display:none;margin-left:auto;background:transparent;border:1px solid var(--gold-border);color:var(--gold);padding:2px 10px;border-radius:4px;cursor:pointer;font-size:8px;font-family:inherit;white-space:nowrap;flex-shrink:0">↻ PRICES</button>
</div>

<div id="tabs">

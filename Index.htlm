  <button class="tab-btn" onclick="showTab('watchlist')">👁 WATCHLIST</button>
  <button class="tab-btn" onclick="showTab('crypto')">₿ CRYPTO</button>
  <button class="tab-btn" onclick="showTab('detail')">🧠 ANALYSIS</button>
  <button class="tab-btn" onclick="showTab('profile')">👤 PROFILE</button>
  <button class="tab-btn" id="admin-tab" onclick="showTab('admin')" style="display:none">⚙️ ADMIN</button>
</div>

<!-- SCANNER VIEW -->

